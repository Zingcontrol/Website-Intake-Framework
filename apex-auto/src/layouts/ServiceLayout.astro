---
import Layout from './Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import type { Service } from '../data/services';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';

interface Props {
  service: Service;
}

const { service } = Astro.props;
const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0247';

// Filter testimonials for this service
const serviceReviews = testimonials.filter(t => t.service === service.shortTitle || t.service === service.title);
const allReviews = serviceReviews.length >= 2 ? serviceReviews : testimonials.slice(0, 3);

// Get related services
const related = service.relatedServices
  .map(slug => services[slug])
  .filter(Boolean);

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "provider": {
    "@type": "AutoRepair",
    "name": "Apex Auto Service",
    "telephone": "+19725550247",
  },
  "areaServed": ["Plano", "Frisco", "Allen", "McKinney", "Richardson"],
  "description": service.description,
};
---

<Layout
  title={`${service.title} in Plano & DFW`}
  description={`Apex Auto Service — ${service.title} in Dallas-Fort Worth. ASE-certified, NAPA AutoCare, AAA Approved. Written estimate before work begins. Call ${phone}.`}
  schema={schema}
  ogImage={service.heroImage}
>
  {/* Mini Hero */}
  <Hero
    headline={service.headline}
    highlightText=""
    subheadline={service.description}
    bgImage={service.heroImage}
    showStats={false}
    compact={true}
  />

  <TrustBar />

  {/* Breadcrumb */}
  <section class="py-4 bg-brand-gray">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <BreadcrumbNav items={[
        { label: 'Home', href: base || '/' },
        { label: service.title },
      ]} />
    </div>
  </section>

  {/* Features Grid */}
  <section class="py-20 bg-white" aria-label="Service features">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="section-heading--accent mx-auto">Why Choose Apex Auto for {service.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {service.features.map((feature, i) => (
          <div class="card" data-animate="fade-up" data-animate-delay={String(i * 100)}>
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center text-brand-red mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-card-title text-brand-charcoal mb-2">{feature.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Testimonials */}
  <TestimonialCarousel
    reviews={allReviews}
    heading={`What Customers Say About Our ${service.title}`}
    subheading="Real reviews from DFW homeowners."
  />

  {/* FAQ */}
  {service.faqs.length > 0 && (
    <FAQAccordion
      items={service.faqs}
      heading={`${service.title} FAQs`}
      subheading={`Common questions about ${service.title.toLowerCase()} service.`}
    />
  )}

  {/* Related Services */}
  {related.length > 0 && (
    <section class="py-16 bg-brand-gray" aria-label="Related services">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <h2 class="section-heading text-center mb-10" data-animate="fade-up">Related Services</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map((rel, i) => (
            <a href={`${base}/services/${rel.slug}`} class="card group" data-animate="fade-up" data-animate-delay={String(i * 100)}>
              <h3 class="text-card-title text-brand-charcoal group-hover:text-brand-red transition-colors mb-2">{rel.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed line-clamp-2">{rel.description}</p>
              <div class="mt-4 flex items-center gap-1 text-brand-red font-semibold text-sm">
                Learn more
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
