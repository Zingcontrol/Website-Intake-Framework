---
interface Step {
  number: number;
  title: string;
  description: string;
  icon: string;
}
interface Props {
  heading?: string;
  subheading?: string;
  steps?: Step[];
}
const {
  heading = 'Getting Your Car Fixed Is Simple',
  subheading = 'Drop in or call ahead — we get you in and out as fast as possible.',
  steps = [
    { number: 1, title: 'Drop Off or Call Ahead', description: 'No appointment needed for most services. Walk in any time or call to guarantee a bay when you arrive.', icon: 'phone' },
    { number: 2, title: 'We Diagnose & Explain', description: 'An ASE-certified tech inspects your vehicle and walks you through exactly what we found — in plain English.', icon: 'search' },
    { number: 3, title: 'Written Estimate First', description: 'You get the full price in writing before we touch anything. No surprises, no pressure, no hidden fees.', icon: 'document' },
    { number: 4, title: 'Fixed Right, Fast', description: 'We complete the repair and call you when it is ready. Most jobs are same-day or next-morning.', icon: 'check' },
  ]
} = Astro.props;

const icons: Record<string, string> = {
  phone: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>',
  search: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>',
  document: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>',
  check: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>',
};
---

<section class="py-20 bg-white" aria-label="How it works">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="section-heading--accent mx-auto">{heading}</h2>
      <p class="section-sub mx-auto mt-4">{subheading}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-4 relative">
      {/* Connecting line (desktop only) */}
      <div class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-brand-red via-brand-orange to-brand-red opacity-20" aria-hidden="true"></div>

      {steps.map((step, i) => (
        <div class="relative text-center" data-animate="fade-up" data-animate-delay={String(i * 150)}>
          {/* Number circle */}
          <div class="w-24 h-24 rounded-full bg-brand-light mx-auto mb-6 flex items-center justify-center relative z-10 border-4 border-white shadow-card">
            <svg class="w-10 h-10 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[step.icon] || icons.check} />
          </div>
          {/* Step number label */}
          <div class="text-label text-brand-orange uppercase mb-2">Step {step.number}</div>
          <h3 class="text-card-title text-brand-charcoal mb-2">{step.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
