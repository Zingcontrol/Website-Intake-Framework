---
interface Props {
  name: string;
  location: string;
  rating: number;
  text: string;
  service?: string;
}
const { name, location, rating, text, service } = Astro.props;
---

<article class="card p-8 flex flex-col h-full">
  {/* Decorative quote */}
  <svg class="w-10 h-10 text-brand-orange/20 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
  </svg>

  {/* Stars */}
  <div class="flex gap-0.5 mb-4" aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg class={`w-5 h-5 ${i < rating ? 'text-yellow-400' : 'text-gray-200'}`} fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  {/* Review text */}
  <p class="text-gray-700 leading-relaxed italic flex-1 mb-6">"{text}"</p>

  {/* Reviewer */}
  <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
    <div>
      <div class="font-bold text-brand-charcoal text-sm">{name}</div>
      <div class="text-gray-500 text-xs">{location}</div>
    </div>
    {service && (
      <span class="text-xs font-medium bg-brand-light text-brand-red px-3 py-1 rounded-badge">{service}</span>
    )}
  </div>
</article>
