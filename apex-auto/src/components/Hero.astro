---
import StatCounter from './StatCounter.astro';

interface Props {
  headline?: string;
  highlightText?: string;
  subheadline?: string;
  bgImage?: string;
  showStats?: boolean;
  compact?: boolean;
}

const {
  headline = "DFW's Most Trusted",
  highlightText = 'Auto Service',
  subheadline = "Honest answers, fair prices, fast turnaround. ASE-certified technicians serving Plano, Frisco, Allen, McKinney, and Richardson. No appointment needed for most services.",
  bgImage = 'https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=1920&q=80',
  showStats = true,
  compact = false,
} = Astro.props;

const phone = '(972) 555-0247';
const base = import.meta.env.BASE_URL;
---

<section class={`relative overflow-hidden ${compact ? 'py-16 md:py-24' : 'min-h-[85vh] flex items-center'}`}>
  {/* Background image */}
  <img
    src={bgImage}
    alt=""
    role="presentation"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />
  {/* Dark gradient overlay */}
  <div class="absolute inset-0 bg-gradient-to-r from-brand-charcoal/95 via-brand-charcoal/85 to-brand-charcoal/40"></div>
  {/* Subtle pattern */}
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class={`flex flex-col ${showStats ? 'lg:flex-row lg:items-center lg:gap-16' : ''}`}>
      {/* Left content */}
      <div class={showStats ? 'lg:w-[60%]' : 'max-w-3xl'}>
        {/* Badge */}
        <div class="inline-flex items-center gap-2 bg-white/10 text-brand-orange font-semibold text-sm px-4 py-2 rounded-badge mb-6 border border-brand-orange/30 backdrop-blur-sm" data-animate="fade-in">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          ASE Certified · NAPA AutoCare Center · AAA Approved
        </div>

        {/* Headline */}
        <h1 class={`font-extrabold text-white leading-tight mb-6 ${compact ? 'text-hero-sm md:text-display' : 'text-hero-sm md:text-hero'}`} data-animate="fade-up">
          {headline}<br />
          <span class="gradient-text">{highlightText}</span><br />
          & Repair
        </h1>

        <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-xl leading-relaxed" data-animate="fade-up" data-animate-delay="100">
          {subheadline}
        </p>

        {/* CTA row */}
        <div class="flex flex-col sm:flex-row gap-4 mb-10" data-animate="fade-up" data-animate-delay="200">
          <a
            href={`${base}/contact`}
            class="btn-primary text-base"
            onclick="trackEvent('cta_click', {location: 'hero', cta: 'schedule_service'})"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Schedule Service
          </a>
          <a
            href={`tel:${phone.replace(/\D/g,'')}`}
            class="btn-secondary text-base"
            onclick="trackEvent('phone_click', {location: 'hero'})"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            Call {phone}
          </a>
        </div>

        {/* Social proof strip */}
        <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-400" data-animate="fade-up" data-animate-delay="300">
          <div class="flex items-center gap-1.5">
            <div class="flex text-yellow-400">
              {'★★★★★'.split('').map(s => <span>{s}</span>)}
            </div>
            <span class="text-white font-semibold">4.9</span>
            <span>· 312 Google reviews</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>No appointment needed</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Honest estimates before work begins</span>
          </div>
        </div>
      </div>

      {/* Right side — stat counters */}
      {showStats && (
        <div class="hidden lg:flex lg:w-[40%] flex-col gap-4 mt-12 lg:mt-0">
          <div class="card--glass p-8 rounded-card">
            <div class="grid grid-cols-1 gap-8">
              <StatCounter value={13} suffix="+" label="Years Serving DFW" />
              <StatCounter value={12000} suffix="+" label="Vehicles Serviced" />
              <StatCounter value={4.9} suffix="" label="Google Rating" />
            </div>
          </div>
        </div>
      )}
    </div>

    {/* Scroll indicator */}
    {!compact && (
      <div class="hidden md:flex justify-center mt-16 animate-bounce-subtle" aria-hidden="true">
        <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    )}
  </div>
</section>
