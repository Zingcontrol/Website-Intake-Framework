---
import Testimonial from './Testimonial.astro';

interface Review {
  name: string;
  location: string;
  rating: number;
  text: string;
  service?: string;
}
interface Props {
  reviews: Review[];
  heading?: string;
  subheading?: string;
}
const {
  reviews,
  heading = 'What Our Customers Say',
  subheading = 'Real reviews from homeowners across Dallas–Fort Worth.',
} = Astro.props;
---

<section class="py-20 bg-brand-warm-gray" aria-label="Customer reviews">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    {/* Header with rating summary */}
    <div class="text-center mb-12" data-animate="fade-up">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="text-5xl font-extrabold text-brand-charcoal">4.9</span>
        <div class="flex flex-col items-start">
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-sm text-gray-500">Based on 194 Google reviews</span>
        </div>
      </div>
      <h2 class="section-heading">{heading}</h2>
      <p class="section-sub mx-auto">{subheading}</p>
    </div>

    {/* Carousel */}
    <div class="relative">
      <div id="testimonial-track" class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 -mx-4 px-4 md:mx-0 md:px-0 scrollbar-hide">
        {reviews.map((review) => (
          <div class="snap-start flex-shrink-0 w-[85%] md:w-[calc(33.333%-1rem)]">
            <Testimonial {...review} />
          </div>
        ))}
      </div>

      {/* Dot indicators */}
      <div id="testimonial-dots" class="flex justify-center gap-2 mt-6">
        {reviews.map((_, i) => (
          <button
            class={`w-2.5 h-2.5 rounded-full transition-all duration-200 ${i === 0 ? 'bg-brand-red w-6' : 'bg-gray-300'}`}
            data-index={i}
            aria-label={`Go to review ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const track = document.getElementById('testimonial-track');
  const dots = document.querySelectorAll('#testimonial-dots button');
  if (track && dots.length) {
    // Update dots on scroll
    const cards = track.children;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = Array.from(cards).indexOf(entry.target);
          dots.forEach((dot, i) => {
            dot.classList.toggle('bg-brand-red', i === idx);
            dot.classList.toggle('w-6', i === idx);
            dot.classList.toggle('bg-gray-300', i !== idx);
            dot.classList.toggle('w-2.5', i !== idx);
          });
        }
      });
    }, { root: track, threshold: 0.6 });

    Array.from(cards).forEach(card => observer.observe(card));

    // Click dots to scroll
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const idx = parseInt((dot as HTMLElement).dataset.index || '0');
        const card = cards[idx] as HTMLElement;
        track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: 'smooth' });
      });
    });

    // Auto-advance on desktop (pause on hover)
    let autoPlay: ReturnType<typeof setInterval> | null = null;
    function startAutoPlay() {
      if (window.innerWidth < 768) return;
      autoPlay = setInterval(() => {
        const scrollLeft = track.scrollLeft;
        const maxScroll = track.scrollWidth - track.clientWidth;
        if (scrollLeft >= maxScroll - 10) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: (cards[0] as HTMLElement).offsetWidth + 24, behavior: 'smooth' });
        }
      }, 5000);
    }
    startAutoPlay();
    track.addEventListener('mouseenter', () => { if (autoPlay) clearInterval(autoPlay); });
    track.addEventListener('mouseleave', startAutoPlay);
  }
</script>
