---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';

const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0247';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Schedule Auto Service — Apex Auto Service",
  "url": "https://zingcontrol.github.io/Website-Intake-Framework/contact",
};
---

<Layout
  title="Schedule Auto Service"
  description="Schedule auto service with Apex Auto Service. Same-day available. Call (972) 555-0247 or use our online form."
  schema={schema}
>
  <Hero
    headline="Let's Get Your Car Fixed"
    highlightText=""
    subheadline="Fill out the form below and we'll reach out within 30 minutes during business hours. Or call us directly — we're ready to help."
    bgImage="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=1920&q=80"
    showStats={false}
    compact={true}
  />

  <section class="py-4 bg-brand-gray">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <BreadcrumbNav items={[
        { label: 'Home', href: base || '/' },
        { label: 'Contact' },
      ]} />
    </div>
  </section>

  <section class="py-16 bg-white" aria-label="Contact form">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        {/* Form — 3 cols */}
        <div class="lg:col-span-3" data-animate="slide-left">
          <h2 class="section-heading--accent mb-8">Request Service</h2>

          <form action="#" method="POST" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-semibold text-brand-charcoal mb-1.5">First Name *</label>
                <input type="text" id="first-name" name="first-name" required
                  class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-semibold text-brand-charcoal mb-1.5">Last Name *</label>
                <input type="text" id="last-name" name="last-name" required
                  class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="phone-number" class="block text-sm font-semibold text-brand-charcoal mb-1.5">Phone *</label>
                <input type="tel" id="phone-number" name="phone" required
                  class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-brand-charcoal mb-1.5">Email</label>
                <input type="email" id="email" name="email"
                  class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="service" class="block text-sm font-semibold text-brand-charcoal mb-1.5">Service Needed *</label>
                <select id="service" name="service" required
                  class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm bg-white">
                  <option value="">Select a service...</option>
                  <option>Oil Change & Lube</option>
                  <option>Brake Repair</option>
                  <option>AC & Heating</option>
                  <option>Tires & Alignment</option>
                  <option>Engine Diagnostics</option>
                  <option>Transmission Service</option>
                  <option>Pre-Purchase Inspection</option>
                  <option>State Inspection</option>
                  <option>Not sure — need help deciding</option>
                </select>
              </div>
              <div>
                <label for="city" class="block text-sm font-semibold text-brand-charcoal mb-1.5">City *</label>
                <select id="city" name="city" required
                  class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm bg-white">
                  <option value="">Select your city...</option>
                  <option>Plano</option>
                  <option>Frisco</option>
                  <option>Allen</option>
                  <option>McKinney</option>
                  <option>Richardson</option>
                  <option>Other DFW area</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-brand-charcoal mb-1.5">Message (optional)</label>
              <textarea id="message" name="message" rows="4"
                class="w-full px-4 py-3 rounded-button border border-gray-200 focus:border-brand-red focus:ring-2 focus:ring-brand-red/20 outline-none transition-all text-sm resize-y"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full text-base" onclick="trackEvent('form_submit', {form: 'contact'})">
              Request Service Appointment
            </button>
          </form>
        </div>

        {/* Contact info — 2 cols */}
        <div class="lg:col-span-2 space-y-6" data-animate="slide-right">
          <div class="card--elevated p-6">
            <h3 class="text-card-title text-brand-charcoal mb-4">Contact Info</h3>
            <address class="not-italic space-y-4 text-sm text-gray-600">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <div>4521 Preston Road<br/>Plano, TX 75093</div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                <a href={`tel:${phone.replace(/\D/g,'')}`} class="text-brand-red font-semibold hover:text-brand-red-dark">{phone}</a>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  Mon–Fri: 7am–7pm<br/>
                  Sat: 8am–5pm<br/>
                  <span class="text-brand-orange font-semibold">24/7 Emergency (Club members)</span>
                </div>
              </div>
            </address>
          </div>

          <div class="card p-6 bg-brand-light border-brand-red/20">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="font-bold text-brand-charcoal text-sm">Fast Response</span>
            </div>
            <p class="text-sm text-gray-600">We respond to all service requests within 30 minutes during business hours. Most calls are scheduled for same-day service.</p>
          </div>

          <div class="card p-6 bg-brand-light border-brand-red/20">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <span class="font-bold text-brand-charcoal text-sm">Your Info Is Safe</span>
            </div>
            <p class="text-sm text-gray-600">We never share your information with third parties. Your data is used only to schedule and deliver your service.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
