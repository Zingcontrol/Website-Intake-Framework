---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import LocationBlock from '../components/LocationBlock.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { testimonials } from '../data/testimonials';
import { generalFaqs } from '../data/faqs';

const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0247';

const serviceCards = [
  {
    title: 'Oil Change & Lube',
    description: 'In and out in 30 minutes — no appointment needed. Every oil change includes a free multi-point inspection.',
    href: `${base}/services/oil-change`,
    image: 'https://images.unsplash.com/photo-1615906655593-ad0386982a0f?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
    urgent: false,
  },
  {
    title: 'Brake Repair',
    description: "Grinding or squealing? Don't wait. Free brake inspection — most jobs completed same day.",
    href: `${base}/services/brakes`,
    image: 'https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    urgent: true,
  },
  {
    title: 'AC & Heating',
    description: 'Car AC blowing warm? Heater not working? We diagnose and fix all makes and models with upfront pricing.',
    href: `${base}/services/ac-heating`,
    image: 'https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    urgent: false,
  },
  {
    title: 'Tires & Alignment',
    description: 'Name-brand tires, free rotation with every oil change, and computerized alignments. All in one stop.',
    href: `${base}/services/tires`,
    image: 'https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
    urgent: false,
  },
  {
    title: 'Engine Diagnostics',
    description: 'Check engine light on? Professional scan tools and root-cause analysis — not just code reading.',
    href: `${base}/services/diagnostics`,
    image: 'https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>`,
    urgent: true,
  },
  {
    title: 'Transmission',
    description: 'Slipping gears? Fluid service to full rebuild — straight diagnosis, honest recommendation on repair vs. replace.',
    href: `${base}/services/transmission`,
    image: 'https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>`,
    urgent: false,
  },
];

const locationCards = [
  { city: 'Plano', responseTime: 'Headquarters — same-day service', description: 'Our main shop. Plano drivers enjoy the fastest turnarounds and walk-in availability every day.', href: `${base}/locations/plano`, isHQ: true },
  { city: 'Frisco', responseTime: 'Same-day appointments', description: 'Frisco commuters trust Apex Auto for fast, honest service on every make and model.', href: `${base}/locations/frisco` },
  { city: 'Allen', responseTime: '10–15 min from our shop', description: 'Allen families count on Apex Auto for transparent pricing and no-upsell service.', href: `${base}/locations/allen` },
  { city: 'McKinney', responseTime: 'Same-day available', description: 'From historic downtown to new subdivisions — McKinney drivers know us by name.', href: `${base}/locations/mckinney` },
  { city: 'Richardson', responseTime: '10–15 min from our shop', description: 'Richardson residents make the short drive knowing they will get honest answers and fair prices.', href: `${base}/locations/richardson` },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AutoRepair",
      "name": "Apex Auto Service",
      "url": "https://zingcontrol.github.io/Website-Intake-Framework/apex-auto",
      "telephone": "+19725550247",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "4521 Preston Road",
        "addressLocality": "Plano",
        "addressRegion": "TX",
        "postalCode": "75093",
        "addressCountry": "US"
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "18:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "16:00" }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "312",
        "bestRating": "5"
      },
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "ASE Certification" },
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "NAPA AutoCare Center" },
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "AAA Approved Auto Repair" }
      ],
      "areaServed": ["Plano", "Frisco", "Allen", "McKinney", "Richardson"]
    },
    {
      "@type": "WebSite",
      "url": "https://zingcontrol.github.io/Website-Intake-Framework/apex-auto",
      "name": "Apex Auto Service"
    }
  ]
};

const whyUs = [
  { title: 'Honest Estimates Before We Touch Anything', detail: 'You know the price before we start. No surprises, no add-ons, no pressure. Just a clear answer on what it will cost and what happens if you choose not to repair it.' },
  { title: 'ASE-Certified Technicians Only', detail: 'Every Apex technician holds ASE certification — the nationally recognized standard. You get expertise and accountability, not guesswork.' },
  { title: 'No Appointment Needed for Most Services', detail: 'Walk in for oil changes, tire rotations, and quick repairs any time during business hours. We will have you back on the road as fast as possible.' },
  { title: '13 Years of Serving DFW Drivers', detail: 'Local, accountable, and here next year. We are not a chain shop — we are a team with real relationships in this community.' },
];
---

<Layout
  title="Auto Service & Repair in Plano & DFW"
  description="Apex Auto Service — Honest auto repair in Plano, TX. ASE-certified, NAPA AutoCare, AAA Approved. Oil changes, brakes, diagnostics, tires & more. No appointment needed. Call (972) 555-0247."
  schema={schema}
>
  {/* 1. Announcement Bar */}
  <AnnouncementBar
    text="Spring Special — $39.95 Full-Synthetic Oil Change + Free Tire Rotation"
    ctaLabel="Claim It"
    ctaHref={`${base}/contact`}
  />

  {/* 2. Hero */}
  <Hero />

  {/* 3. Trust Bar */}
  <TrustBar />

  {/* 4. Process Steps */}
  <ProcessSteps />

  {/* 4b. Why Choose Apex — split photo */}
  <section class="bg-white overflow-hidden" aria-label="Why choose Apex Auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[520px]">
      {/* Photo side */}
      <div class="relative h-72 sm:h-96 lg:h-auto order-2 lg:order-1" data-animate="slide-left">
        <img
          src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=900&q=80"
          alt="Apex Auto Service ASE-certified technician working on a vehicle"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/70 via-brand-charcoal/20 to-transparent"></div>
        {/* Floating badge */}
        <div class="absolute bottom-6 left-6 bg-white rounded-card p-4 shadow-card-hover max-w-xs">
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 bg-brand-red rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            </div>
            <div>
              <div class="flex gap-0.5 mb-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <div class="font-bold text-brand-charcoal text-sm">312 Google Reviews</div>
              <div class="text-xs text-gray-500">DFW's highest-rated auto shop</div>
            </div>
          </div>
        </div>
      </div>

      {/* Content side */}
      <div class="bg-brand-light flex items-center px-8 py-14 lg:px-14 order-1 lg:order-2" data-animate="slide-right">
        <div class="max-w-lg">
          <div class="text-label text-brand-red uppercase mb-3">Why DFW Drivers Choose Us</div>
          <h2 class="section-heading mb-8">Honest Answers. Fair Prices. Done Right.</h2>
          <div class="space-y-6">
            {whyUs.map(item => (
              <div class="flex gap-4">
                <div class="w-6 h-6 rounded-full bg-brand-red/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-bold text-brand-charcoal text-sm mb-0.5">{item.title}</div>
                  <div class="text-sm text-gray-600 leading-relaxed">{item.detail}</div>
                </div>
              </div>
            ))}
          </div>
          <a href={`${base}/contact`} class="btn-primary mt-8 inline-flex">
            Schedule Service Today
          </a>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider from="#F7F8FA" to="#F7F8FA" variant="wave" />

  {/* 5. Services Grid */}
  <section class="py-20 bg-brand-gray" aria-label="Our services">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="section-heading--accent mx-auto">Everything Your Vehicle Needs</h2>
        <p class="section-sub mx-auto mt-4">From a quick oil change to a major repair, Apex Auto gets it done right the first time.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceCards.map((svc, i) => (
          <div data-animate="fade-up" data-animate-delay={String(i * 100)}>
            <ServiceCard {...svc} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider from="#F7F8FA" to="#F9F7F4" variant="curve" />

  {/* 6. Testimonials */}
  <TestimonialCarousel reviews={testimonials} />

  {/* 7. Financing / Value CTA */}
  <section class="py-20 bg-brand-charcoal relative overflow-hidden" aria-label="Financing and value">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div data-animate="slide-left">
          <div class="text-label text-brand-orange uppercase mb-4">No-Surprise Pricing</div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
            Big Repair? We Have Financing Options.
          </h2>
          <p class="text-gray-300 text-lg mb-6 leading-relaxed">
            Unexpected repairs happen. If the bill is bigger than you planned, ask about our financing options before you authorize work. We want to keep you on the road — not in debt stress.
          </p>
          <ul class="space-y-3 mb-8">
            {[
              'Written estimate before any work begins',
              'Financing with approved credit',
              '12-month / 12,000-mile warranty on repairs',
              'No pressure — you decide what to fix and when',
            ].map(item => (
              <li class="flex items-center gap-3 text-gray-200 text-sm">
                <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href={`${base}/contact`} class="btn-primary text-base">
            Schedule Service
          </a>
        </div>
        <div data-animate="slide-right" class="relative">
          <div class="relative rounded-section overflow-hidden min-h-[340px]">
            <img
              src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=900&q=80"
              alt="Apex Auto technician explaining repairs to a customer"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-charcoal/90 via-brand-charcoal/50 to-brand-charcoal/10"></div>
            <div class="relative p-8 flex flex-col justify-end min-h-[340px]">
              <blockquote class="text-white text-lg font-medium italic leading-relaxed">
                "They told me exactly what was wrong, what it would cost, and what would happen if I waited. No pressure. That is the kind of shop I want for my family."
              </blockquote>
              <div class="mt-4 text-gray-300 text-sm">— Robert M., Richardson, TX</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* 8. Service Areas */}
  <section class="py-20 bg-brand-light" aria-label="Service areas">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="section-heading--accent mx-auto">Serving the DFW Metroplex</h2>
        <p class="section-sub mx-auto mt-4">Headquartered in Plano — convenient to drivers across North Texas.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {locationCards.map((loc, i) => (
          <div data-animate="slide-right" data-animate-delay={String(i * 100)}>
            <LocationBlock {...loc} />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 9. FAQ */}
  <FAQAccordion items={generalFaqs} />

</Layout>
