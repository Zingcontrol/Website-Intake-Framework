---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0183';
---

<Layout
  title="CoolBreeze Club Maintenance Plan"
  description="CoolBreeze Club — $149/year. Two seasonal tune-ups, priority scheduling, 15% off repairs, and 24/7 emergency access. Join today."
>
  <section class="py-20 bg-brand-navy">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center gap-2 bg-brand-orange/20 text-brand-orange font-bold text-sm px-4 py-2 rounded-full mb-6 border border-brand-orange/30">
        ★ Best Value · Most Popular Plan
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">CoolBreeze Club</h1>
      <p class="text-xl text-gray-300 mb-3">$149 / year</p>
      <p class="text-gray-400 max-w-xl mx-auto mb-10">
        One flat annual fee. Two tune-ups, priority scheduling, repair discounts, and 24/7 emergency access.
        Most members save over $300 in year one.
      </p>
      <a
        href={`${base}/contact`}
        class="btn-primary text-base px-8"
        onclick="trackEvent('cta_click', {location: 'club_page', cta: 'club_signup'})"
      >
        Join the Club — $149/year
      </a>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="section-heading text-center mb-12">Everything Included</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {[
          { title: '2 Seasonal Tune-Ups', desc: 'One in spring (AC prep) and one in fall (heating prep). We come to you — no scheduling stress.' },
          { title: 'Priority Same-Day Scheduling', desc: 'Club members move to the front of the line. No waiting 3 days when it\'s 100° outside.' },
          { title: '15% Off All Repairs', desc: 'Every service call, every repair, every time. Adds up fast on major work.' },
          { title: '24/7 Emergency Line', desc: 'Dedicated emergency number for existing customers. Not an answering service — a real tech.' },
          { title: 'Filter Replacement Reminders', desc: 'We track your filter schedule and send reminders so you don\'t have to remember.' },
          { title: 'Annual System Report', desc: 'After each tune-up, a written efficiency report with recommendations — no surprise upsell pressure.' },
        ].map(item => (
          <div class="card flex gap-4">
            <div class="w-10 h-10 rounded-xl bg-brand-light flex items-center justify-center text-brand-blue flex-shrink-0">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-brand-navy mb-1">{item.title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 bg-brand-gray rounded-2xl p-8 text-center">
        <p class="text-gray-600 mb-2 text-sm">Average cost of a single tune-up: <strong class="text-gray-800">$89–$129</strong></p>
        <p class="text-gray-600 mb-2 text-sm">Two tune-ups alone: <strong class="text-gray-800">$178–$258 value</strong></p>
        <p class="text-gray-600 mb-6 text-sm">Club membership: <strong class="text-brand-blue text-base">$149/year</strong></p>
        <a href={`${base}/contact`} class="btn-primary" onclick="trackEvent('cta_click', {location: 'club_value_section', cta: 'club_signup'})">
          Join Today — $149/year
        </a>
      </div>
    </div>
  </section>
</Layout>
