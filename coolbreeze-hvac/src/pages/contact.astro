---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0183';
---
<Layout
  title="Book HVAC Service"
  description="Schedule heating or cooling service with CoolBreeze HVAC. Same-day available. Call (972) 555-0183 or use our online form."
>
  <section class="py-16 bg-brand-gray">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h1 class="section-heading">Request Service</h1>
        <p class="section-sub mx-auto text-center">Fill out the form below and we'll confirm your appointment within 30 minutes during business hours.</p>
      </div>

      <div class="card p-8 md:p-10">
        <form
          name="service-request"
          method="POST"
          data-netlify="true"
          class="space-y-6"
          onsubmit="trackEvent('form_submit', {form: 'service_request'})"
        >
          <input type="hidden" name="form-name" value="service-request" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">First Name *</label>
              <input required type="text" name="first_name" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Last Name *</label>
              <input required type="text" name="last_name" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone *</label>
              <input required type="tel" name="phone" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
              <input type="email" name="email" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Service Needed *</label>
            <select required name="service" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent bg-white">
              <option value="">Select a service...</option>
              <option>AC Repair</option>
              <option>Heating Repair</option>
              <option>Furnace Repair</option>
              <option>Heat Pump</option>
              <option>New Installation / Replacement</option>
              <option>Maintenance / Tune-Up</option>
              <option>Emergency Service</option>
              <option>CoolBreeze Club Signup</option>
              <option>Not sure — need a diagnosis</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">City *</label>
            <select required name="city" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent bg-white">
              <option value="">Select your city...</option>
              <option>Plano</option><option>Frisco</option><option>Allen</option>
              <option>McKinney</option><option>Richardson</option><option>Other DFW</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Describe the issue <span class="text-gray-400 font-normal">(optional)</span></label>
            <textarea name="message" rows="3" class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue focus:border-transparent resize-none"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full justify-center">
            Request Service Appointment
          </button>
          <p class="text-center text-xs text-gray-500">
            Or call us directly at <a href={`tel:9725550183`} class="font-semibold text-brand-blue">{phone}</a>
          </p>
        </form>
      </div>
    </div>
  </section>
</Layout>
