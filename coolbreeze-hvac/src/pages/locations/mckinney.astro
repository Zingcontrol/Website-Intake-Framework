---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0183';
const schema = {
  "@context": "https://schema.org",
  "@type": "HVACBusiness",
  "name": "CoolBreeze HVAC & Air — McKinney, TX",
  "telephone": "+19725550183",
  "areaServed": {
    "@type": "City",
    "name": "McKinney",
    "addressRegion": "TX"
  },
  "description": "HVAC repair and installation in McKinney, TX. NATE-certified. Same-day available."
};
---

<Layout
  title="HVAC Repair in McKinney, TX"
  description="CoolBreeze HVAC serves McKinney, TX — fast heating and cooling service, NATE-certified technicians, Carrier Factory Authorized Dealer. Call (972) 555-0183."
  schema={schema}
>
  <section class="py-16 bg-brand-gray">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav class="text-sm text-gray-500 mb-6">
        <a href={base || '/'} class="hover:text-brand-blue">Home</a>
        <span class="mx-2">/</span>
        <span class="text-gray-800 font-medium">HVAC in McKinney, TX</span>
      </nav>
      <h1 class="section-heading mb-4">HVAC Repair & Service in McKinney, TX</h1>
      <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-2xl">
        Rapid growth means aging original HVAC systems across McKinney. We specialize in replacements and tune-ups for homes 10-20 years old. Fast response times, upfront pricing, and NATE-certified technicians who know the area.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a href={`${base}/contact`} class="btn-primary" onclick="trackEvent('cta_click', {location: 'location_page', city: 'mckinney', cta: 'book'})">
          Book Service in McKinney
        </a>
        <a href="tel:9725550183" class="btn-outline" onclick="trackEvent('phone_click', {location: 'location_page', city: 'mckinney'})">
          Call {phone}
        </a>
      </div>
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="card">
          <h2 class="font-bold text-brand-navy text-lg mb-3">Response Time</h2>
          <p class="text-gray-600">Average dispatch to McKinney: <strong class="text-brand-blue">35 min</strong>. Same-day service available for most repairs.</p>
        </div>
        <div class="card">
          <h2 class="font-bold text-brand-navy text-lg mb-3">Coverage Area</h2>
          <p class="text-gray-600">We serve all of McKinney (75069) and surrounding communities throughout DFW.</p>
        </div>
      </div>
      <h2 class="text-2xl font-extrabold text-brand-navy mb-6">Services Available in McKinney</h2>
      <div class="grid sm:grid-cols-2 gap-4 mb-12">
        {[
          ['AC Repair', '/services/ac-repair'],
          ['Heating Repair', '/services/heating-repair'],
          ['Furnace Repair', '/services/furnace-repair'],
          ['Heat Pump', '/services/heat-pump'],
          ['New Installation', '/services/installation'],
          ['Maintenance', '/services/maintenance'],
        ].map(([label, href]) => (
          <a href={`${base}${href}`} class="card flex items-center justify-between group hover:border-brand-blue/40">
            <span class="font-semibold text-brand-navy group-hover:text-brand-blue transition-colors">{label}</span>
            <svg class="w-4 h-4 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
