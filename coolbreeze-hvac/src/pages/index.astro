---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import LocationBlock from '../components/LocationBlock.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { testimonials } from '../data/testimonials';
import { generalFaqs } from '../data/faqs';

const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0183';

const serviceCards = [
  {
    title: 'AC Repair',
    description: 'Fast diagnosis and repair for any make or model. Same-day service available when you need cooling most.',
    href: `${base}/services/ac-repair`,
    image: 'https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    urgent: false,
  },
  {
    title: 'Heating Repair',
    description: "Don't go cold. Our techs arrive ready to fix most heating problems in a single visit.",
    href: `${base}/services/heating-repair`,
    image: 'https://images.unsplash.com/photo-1576045057995-568f588f82fb?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>`,
    urgent: false,
  },
  {
    title: 'Furnace Repair',
    description: 'Gas, electric, or heat pump furnaces. Certified to work on all major brands including Carrier, Lennox, and Trane.',
    href: `${base}/services/furnace-repair`,
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
    urgent: false,
  },
  {
    title: 'Heat Pump',
    description: 'Installation, repair, and maintenance for heat pump systems. Year-round efficiency for DFW homes.',
    href: `${base}/services/heat-pump`,
    image: 'https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>`,
    urgent: false,
  },
  {
    title: 'New Installation',
    description: 'Right-sized systems, professional installation, factory warranty. As a Carrier FAD, we offer exclusive pricing.',
    href: `${base}/services/installation`,
    image: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>`,
    urgent: false,
  },
  {
    title: 'Emergency Service',
    description: "24/7 emergency response for existing CoolBreeze customers. Breakdowns don't keep business hours.",
    href: `${base}/services/ac-repair`,
    image: 'https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=600&q=80',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    urgent: true,
  },
];

const locationCards = [
  { city: 'Plano', responseTime: 'Headquarters — fastest response', description: 'Our home base. Plano residents get the fastest response times and a team that knows the neighborhood.', href: `${base}/locations/plano`, isHQ: true },
  { city: 'Frisco', responseTime: '30 min response', description: 'Fast-growing Frisco gets fast, reliable HVAC service. From The Star to Stonebriar, we\'re there.', href: `${base}/locations/frisco` },
  { city: 'Allen', responseTime: '25 min response', description: 'Allen families count on CoolBreeze for honest service and same-day repairs.', href: `${base}/locations/allen` },
  { city: 'McKinney', responseTime: '35 min response', description: 'From historic downtown to new developments, McKinney is covered.', href: `${base}/locations/mckinney` },
  { city: 'Richardson', responseTime: '30 min response', description: 'CityLine to Canyon Creek — Richardson homeowners trust CoolBreeze.', href: `${base}/locations/richardson` },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HVACBusiness",
      "name": "CoolBreeze HVAC & Air",
      "url": "https://zingcontrol.github.io/Website-Intake-Framework",
      "telephone": "+19725550183",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "4521 Preston Road",
        "addressLocality": "Plano",
        "addressRegion": "TX",
        "postalCode": "75093",
        "addressCountry": "US"
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "17:00" }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "194",
        "bestRating": "5"
      },
      "hasCredential": [
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "NATE Certification" },
        { "@type": "EducationalOccupationalCredential", "credentialCategory": "Carrier Factory Authorized Dealer" }
      ],
      "areaServed": ["Plano", "Frisco", "Allen", "McKinney", "Richardson"]
    },
    {
      "@type": "WebSite",
      "url": "https://zingcontrol.github.io/Website-Intake-Framework",
      "name": "CoolBreeze HVAC & Air"
    }
  ]
};

const clubFeatures = [
  '2 seasonal tune-ups per year',
  'Priority same-day scheduling',
  '15% off all repairs',
  '24/7 emergency line',
  'Filter replacement reminders',
  'Annual system health report',
];
---

<Layout
  title="Dallas–Fort Worth HVAC Service"
  description="CoolBreeze HVAC — Trusted heating and cooling service in DFW. NATE-certified, Carrier Factory Authorized. Same-day service, upfront pricing. Call (972) 555-0183."
  schema={schema}
>
  {/* 1. Announcement Bar */}
  <AnnouncementBar
    text="Spring AC Tune-Up Special — $89"
    ctaLabel="Book Now"
    ctaHref={`${base}/contact`}
  />

  {/* 2. Hero */}
  <Hero />

  {/* 3. Trust Bar */}
  <TrustBar />

  {/* 4. Process Steps */}
  <ProcessSteps />

  {/* 4b. Why Choose CoolBreeze — split photo */}
  <section class="bg-white overflow-hidden" aria-label="Why choose CoolBreeze">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[520px]">
      {/* Photo side */}
      <div class="relative h-72 sm:h-96 lg:h-auto order-2 lg:order-1" data-animate="slide-left">
        <img
          src="https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=900&q=80"
          alt="CoolBreeze HVAC certified technician servicing a DFW home"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/70 via-brand-navy/20 to-transparent"></div>
        {/* Floating badge */}
        <div class="absolute bottom-6 left-6 bg-white rounded-card p-4 shadow-card-hover max-w-xs">
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 bg-brand-blue rounded-full flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            </div>
            <div>
              <div class="flex gap-0.5 mb-0.5">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <div class="font-bold text-brand-navy text-sm">194 Google Reviews</div>
              <div class="text-xs text-gray-500">DFW's highest-rated HVAC team</div>
            </div>
          </div>
        </div>
      </div>

      {/* Content side */}
      <div class="bg-brand-light flex items-center px-8 py-14 lg:px-14 order-1 lg:order-2" data-animate="slide-right">
        <div class="max-w-lg">
          <div class="text-label text-brand-orange uppercase mb-3">Why Homeowners Choose Us</div>
          <h2 class="section-heading mb-8">We Show Up. We Fix It. We Guarantee It.</h2>
          <div class="space-y-6">
            {[
              { title: 'Same-Day Service, Stocked Trucks', detail: 'Every truck carries parts for DFW\'s most common HVAC brands. Most repairs happen in a single visit — no waiting a week for a part order.' },
              { title: 'NATE-Certified Technicians Only', detail: 'Every CoolBreeze tech holds national NATE certification — the industry gold standard. You get expertise, not guesswork.' },
              { title: 'Upfront Pricing, No Surprises', detail: 'You approve the price before we start. No add-ons after the fact, no pressure, no hidden diagnostic fees.' },
              { title: '12 Years Serving North Texas', detail: 'Local, accountable, and here next year. We\'re not a franchise call center — we\'re a team that knows your neighborhood.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-6 h-6 rounded-full bg-brand-orange/15 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <div>
                  <div class="font-bold text-brand-navy text-sm mb-0.5">{item.title}</div>
                  <div class="text-sm text-gray-600 leading-relaxed">{item.detail}</div>
                </div>
              </div>
            ))}
          </div>
          <a href={`${base}/contact`} class="btn-primary mt-8 inline-flex">
            Book Service Today
          </a>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider from="#F7F8FA" to="#F7F8FA" variant="wave" />

  {/* 5. Services Grid */}
  <section class="py-20 bg-brand-gray" aria-label="Our services">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="section-heading--accent mx-auto">Everything Your HVAC System Needs</h2>
        <p class="section-sub mx-auto mt-4">From emergency repairs to planned installations, CoolBreeze covers it all.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceCards.map((svc, i) => (
          <div data-animate="fade-up" data-animate-delay={String(i * 100)}>
            <ServiceCard {...svc} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <SectionDivider from="#F7F8FA" to="#F9F7F4" variant="curve" />

  {/* 6. Testimonials */}
  <TestimonialCarousel reviews={testimonials} />

  {/* 7. CoolBreeze Club CTA */}
  <section class="py-20 bg-brand-navy relative overflow-hidden" aria-label="CoolBreeze Club">
    {/* Subtle pattern */}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");" aria-hidden="true"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div data-animate="slide-left">
          <div class="text-label text-brand-orange uppercase mb-4">Membership Program</div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">
            Join the CoolBreeze Club
          </h2>
          <p class="text-gray-300 text-lg mb-6 leading-relaxed">
            One membership. Two tune-ups. Priority service. 15% off repairs. No contracts, cancel anytime.
          </p>
          <div class="flex items-baseline gap-2 mb-8">
            <span class="text-5xl font-extrabold text-white">$149</span>
            <span class="text-gray-400 text-lg">/year</span>
            <span class="text-sm text-gray-500 line-through ml-2">$450+ value</span>
          </div>
          <a href={`${base}/coolbreeze-club`} class="btn-primary text-base">
            Learn About the Club
          </a>
        </div>
        <div data-animate="slide-right" class="relative">
          <div class="relative rounded-section overflow-hidden min-h-[340px]">
            <img
              src="https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=900&q=80"
              alt="Comfortable home — CoolBreeze Club member"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/90 via-brand-navy/50 to-brand-navy/10"></div>
            <div class="relative p-8 flex flex-col justify-end min-h-[340px]">
              <h3 class="text-white font-bold text-lg mb-4">Everything Included:</h3>
              <ul class="space-y-3">
                {clubFeatures.map(feature => (
                  <li class="flex items-center gap-3 text-gray-100 text-sm">
                    <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* 8. Service Areas */}
  <section class="py-20 bg-brand-light" aria-label="Service areas">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12" data-animate="fade-up">
        <h2 class="section-heading--accent mx-auto">Serving the DFW Metroplex</h2>
        <p class="section-sub mx-auto mt-4">Headquartered in Plano, serving families across North Texas.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {locationCards.map((loc, i) => (
          <div data-animate="slide-right" data-animate-delay={String(i * 100)}>
            <LocationBlock {...loc} />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 9. FAQ */}
  <FAQAccordion items={generalFaqs} />

  {/* 10. Footer CTA is built into Footer component */}
</Layout>
