---
const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0183';
const year = new Date().getFullYear();

const services = [
  { label: 'AC Repair', href: `${base}/services/ac-repair` },
  { label: 'Heating Repair', href: `${base}/services/heating-repair` },
  { label: 'Furnace Repair', href: `${base}/services/furnace-repair` },
  { label: 'Heat Pump', href: `${base}/services/heat-pump` },
  { label: 'New Installation', href: `${base}/services/installation` },
  { label: 'Maintenance', href: `${base}/services/maintenance` },
];

const locations = [
  { label: 'Frisco', href: `${base}/locations/frisco` },
  { label: 'Allen', href: `${base}/locations/allen` },
  { label: 'Plano', href: `${base}/locations/plano` },
  { label: 'McKinney', href: `${base}/locations/mckinney` },
  { label: 'Richardson', href: `${base}/locations/richardson` },
];
---

<footer class="bg-brand-navy text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-brand-blue flex items-center justify-center text-white font-black text-lg">CB</div>
          <div>
            <div class="text-white font-extrabold text-lg leading-none">CoolBreeze</div>
            <div class="text-brand-orange text-xs font-semibold">HVAC & Air</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-4">
          Serving Dallas–Fort Worth families since 2012. NATE-certified technicians, Carrier Factory Authorized Dealer.
        </p>
        <a
          href={`tel:${phone.replace(/\D/g,'')}`}
          class="flex items-center gap-2 text-white font-bold hover:text-brand-orange transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          {phone}
        </a>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-sm hover:text-white transition-colors">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Service Areas</h3>
        <ul class="space-y-2">
          {locations.map(l => (
            <li>
              <a href={l.href} class="text-sm hover:text-white transition-colors">{l.label}, TX</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-3 text-sm">
          <li>4521 Preston Road<br />Plano, TX 75093</li>
          <li>Mon–Fri: 7am–7pm<br />Sat: 8am–5pm<br /><span class="text-brand-orange font-semibold">24/7 Emergency (existing customers)</span></li>
          <li>
            <a href={`${base}/contact`} class="btn-primary text-sm px-4 py-2.5 mt-2" style="min-height: 40px; display: inline-flex;">
              Request Service
            </a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>© {year} CoolBreeze HVAC & Air. All rights reserved. TX License #HVAC12847</p>
      <div class="flex gap-4">
        <a href={`${base}/privacy`} class="hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href={`${base}/terms`} class="hover:text-gray-300 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
