---
interface Props {
  city: string;
  state?: string;
  responseTime: string;
  description: string;
  href: string;
  isHQ?: boolean;
}
const { city, state = 'TX', responseTime, description, href, isHQ = false } = Astro.props;
---

<a href={href} class="card group block hover:border-brand-blue/40 transition-all duration-200" data-animate="slide-right">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="text-card-title text-brand-navy group-hover:text-brand-blue transition-colors">{city}, {state}</h3>
        {isHQ && (
          <span class="text-label bg-brand-orange/10 text-brand-orange px-2 py-0.5 rounded-badge">HQ</span>
        )}
      </div>
      <div class="flex items-center gap-1.5 text-sm text-brand-blue font-medium mb-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        {responseTime}
      </div>
      <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
    </div>
    <svg class="w-5 h-5 text-gray-400 group-hover:text-brand-blue group-hover:translate-x-1 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </div>
</a>
