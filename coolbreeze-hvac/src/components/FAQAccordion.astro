---
interface FAQItem {
  question: string;
  answer: string;
}
interface Props {
  items: FAQItem[];
  heading?: string;
  subheading?: string;
  generateSchema?: boolean;
}
const {
  items,
  heading = 'Common Questions',
  subheading = 'Quick answers to what homeowners ask most.',
  generateSchema = true,
} = Astro.props;

const faqSchema = generateSchema ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
} : null;
---

<section class="py-20 bg-white" aria-label="Frequently asked questions">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12" data-animate="fade-up">
      <h2 class="section-heading--accent mx-auto">{heading}</h2>
      <p class="section-sub mx-auto mt-4">{subheading}</p>
    </div>

    <div class="space-y-3">
      {items.map((item, i) => (
        <details class="faq-item group border border-gray-200 rounded-card overflow-hidden" data-animate="fade-up" data-animate-delay={String(i * 80)}>
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none font-semibold text-brand-navy hover:bg-brand-light/50 transition-colors select-none">
            <span>{item.question}</span>
            <svg class="w-5 h-5 text-brand-blue flex-shrink-0 transition-transform duration-200 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"/>
            </svg>
          </summary>
          <div class="px-6 pb-5 text-gray-600 leading-relaxed">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>

  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
</section>
