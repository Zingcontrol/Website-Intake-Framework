---
const badges = [
  {
    icon: 'shield',
    label: 'NATE Certified',
    sub: 'Technicians',
  },
  {
    icon: 'star',
    label: 'Carrier Factory',
    sub: 'Authorized Dealer',
  },
  {
    icon: 'review',
    label: '4.8 Stars',
    sub: '194 Google Reviews',
  },
  {
    icon: 'check',
    label: 'Licensed &',
    sub: 'Insured · TX #HVAC12847',
  },
  {
    icon: 'clock',
    label: '24/7 Emergency',
    sub: 'Existing Customers',
  },
];
---

<section class="bg-brand-blue py-5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-0 lg:divide-x lg:divide-white/20">

      <!-- NATE Certified -->
      <div class="flex items-center gap-3 lg:px-6 first:lg:pl-0 last:lg:pr-0">
        <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div class="text-white">
          <div class="font-bold text-sm leading-tight">NATE Certified</div>
          <div class="text-xs text-blue-100">Technicians</div>
        </div>
      </div>

      <!-- Carrier FAD -->
      <div class="flex items-center gap-3 lg:px-6">
        <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </div>
        <div class="text-white">
          <div class="font-bold text-sm leading-tight">Carrier Factory</div>
          <div class="text-xs text-blue-100">Authorized Dealer</div>
        </div>
      </div>

      <!-- Reviews -->
      <div class="flex items-center gap-3 lg:px-6">
        <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-yellow-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </div>
        <div class="text-white">
          <div class="font-bold text-sm leading-tight">4.8 Stars</div>
          <div class="text-xs text-blue-100">194 Google Reviews</div>
        </div>
      </div>

      <!-- Licensed -->
      <div class="flex items-center gap-3 lg:px-6">
        <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <div class="text-white">
          <div class="font-bold text-sm leading-tight">Licensed & Insured</div>
          <div class="text-xs text-blue-100">TX #HVAC12847</div>
        </div>
      </div>

      <!-- 24/7 -->
      <div class="flex items-center gap-3 lg:px-6">
        <div class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="text-white">
          <div class="font-bold text-sm leading-tight">24/7 Emergency</div>
          <div class="text-xs text-blue-100">Existing Customers</div>
        </div>
      </div>

    </div>
  </div>
</section>
