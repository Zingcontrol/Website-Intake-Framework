---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  urgent?: boolean;
}
const { title, description, href, icon, urgent = false } = Astro.props;
---

<a href={href} class="card group relative flex flex-col gap-4 hover:border-brand-blue/40">
  {urgent && (
    <span class="absolute top-4 right-4 bg-red-100 text-red-700 text-xs font-bold px-2 py-0.5 rounded-full">Emergency</span>
  )}
  <div class="w-12 h-12 rounded-xl bg-brand-light flex items-center justify-center text-brand-blue group-hover:bg-brand-blue group-hover:text-white transition-colors">
    <Fragment set:html={icon} />
  </div>
  <div>
    <h3 class="font-bold text-brand-navy text-lg leading-tight mb-1 group-hover:text-brand-blue transition-colors">
      {title}
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
  </div>
  <div class="mt-auto flex items-center gap-1 text-brand-blue font-semibold text-sm">
    Learn more
    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </div>
</a>
