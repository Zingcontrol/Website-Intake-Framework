---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  urgent?: boolean;
  image?: string;
}
const { title, description, href, icon, urgent = false, image } = Astro.props;
---

<a href={href} class="card group relative flex flex-col gap-4 hover:border-brand-blue/40 border-l-4 border-l-transparent hover:border-l-brand-orange">
  {urgent && (
    <span class="absolute top-4 right-4 flex items-center gap-1.5 bg-red-100 text-red-700 text-xs font-bold px-2.5 py-1 rounded-badge">
      <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse-soft"></span>
      24/7
    </span>
  )}

  {image && (
    <div class="w-full h-32 -mt-6 -mx-6 mb-0 overflow-hidden rounded-t-card" style="width: calc(100% + 3rem);">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
    </div>
  )}

  <div class="w-14 h-14 rounded-2xl bg-brand-light flex items-center justify-center text-brand-blue group-hover:bg-brand-blue group-hover:text-white transition-all duration-200">
    <Fragment set:html={icon} />
  </div>
  <div>
    <h3 class="font-bold text-brand-navy text-card-title leading-tight mb-1.5 group-hover:text-brand-blue transition-colors">
      {title}
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
  </div>
  <div class="mt-auto flex items-center gap-1 text-brand-blue font-semibold text-sm">
    Learn more
    <svg class="w-4 h-4 group-hover:translate-x-1.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </div>
</a>
