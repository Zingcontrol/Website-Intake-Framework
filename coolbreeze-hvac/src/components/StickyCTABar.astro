---
const phone = '(972) 555-0183';
const base = import.meta.env.BASE_URL;
---

<!-- Mobile-only sticky bottom CTA bar -->
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-brand-navy border-t border-white/10 safe-area-bottom">
  <div class="grid grid-cols-2 gap-px">
    <a
      href={`tel:${phone.replace(/\D/g,'')}`}
      class="flex flex-col items-center justify-center gap-1 py-3 bg-brand-blue text-white active:brightness-90 transition-all"
      onclick="trackEvent('phone_click', {location: 'sticky_cta'})"
    >
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
      </svg>
      <span class="text-xs font-bold">Call Now</span>
    </a>
    <a
      href={`${base}/contact`}
      class="flex flex-col items-center justify-center gap-1 py-3 bg-brand-orange text-white active:brightness-90 transition-all"
      onclick="trackEvent('cta_click', {location: 'sticky_cta', cta: 'book_service'})"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <span class="text-xs font-bold">Book Service</span>
    </a>
  </div>
</div>
