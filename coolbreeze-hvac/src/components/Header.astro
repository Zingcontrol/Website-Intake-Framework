---
const base = import.meta.env.BASE_URL;
const phone = '(972) 555-0183';

const nav = [
  { label: 'Services',  href: `${base}/services/ac-repair` },
  { label: 'Locations', href: `${base}/locations/plano` },
  { label: 'CoolBreeze Club', href: `${base}/coolbreeze-club` },
  { label: 'About',     href: `${base}/about` },
  { label: 'Contact',   href: `${base}/contact` },
];
---

<header class="sticky top-0 z-50 bg-brand-navy shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={base || '/'} class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-full bg-brand-blue flex items-center justify-center text-white font-black text-lg leading-none">
          CB
        </div>
        <div class="leading-tight">
          <div class="text-white font-extrabold text-lg leading-none">CoolBreeze</div>
          <div class="text-brand-orange text-xs font-semibold tracking-wide">HVAC & Air</div>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-6">
        {nav.map(item => (
          <a
            href={item.href}
            class="text-gray-300 hover:text-white text-sm font-medium transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a
          href={`tel:${phone.replace(/\D/g,'')}`}
          class="hidden md:flex items-center gap-2 text-white font-bold text-sm hover:text-brand-orange transition-colors"
          onclick="trackEvent('phone_click', {location: 'header'})"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          {phone}
        </a>
        <a
          href={`${base}/contact`}
          class="btn-primary text-sm px-4 py-2.5"
          style="min-height: 40px;"
          onclick="trackEvent('cta_click', {location: 'header', cta: 'book_service'})"
        >
          Book Service
        </a>

        <!-- Mobile menu button -->
        <button
          id="menu-toggle"
          class="lg:hidden text-white p-1"
          aria-label="Open menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-white/10 mt-1 pt-3">
      {nav.map(item => (
        <a
          href={item.href}
          class="block text-gray-300 hover:text-white py-2 text-sm font-medium"
        >
          {item.label}
        </a>
      ))}
      <a
        href={`tel:${phone.replace(/\D/g,'')}`}
        class="flex items-center gap-2 text-brand-orange font-bold mt-3 text-sm"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        {phone}
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
