---
const phone = '(972) 555-0183';
const base = import.meta.env.BASE_URL;
---

<section class="relative bg-brand-navy overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-navy via-[#0d3060] to-brand-blue opacity-90"></div>
  <!-- Pattern overlay -->
  <div class="absolute inset-0 opacity-5" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="max-w-3xl">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-white/10 text-brand-orange font-semibold text-sm px-4 py-2 rounded-full mb-6 border border-brand-orange/30">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        NATE-Certified · Carrier Factory Authorized Dealer
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Dallas–Fort Worth's<br />
        <span class="text-brand-orange">Trusted HVAC</span><br />
        Experts
      </h1>

      <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-xl leading-relaxed">
        Fast, reliable heating and cooling service for DFW families. Same-day service available.
        Upfront pricing. We don't leave until the job is done right.
      </p>

      <!-- CTA row -->
      <div class="flex flex-col sm:flex-row gap-4 mb-10">
        <a
          href={`${base}/contact`}
          class="btn-primary text-base"
          onclick="trackEvent('cta_click', {location: 'hero', cta: 'book_service'})"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Book Service Today
        </a>
        <a
          href={`tel:${phone.replace(/\D/g,'')}`}
          class="btn-secondary text-base"
          onclick="trackEvent('phone_click', {location: 'hero'})"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          Call {phone}
        </a>
      </div>

      <!-- Social proof strip -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-gray-400">
        <div class="flex items-center gap-1.5">
          <div class="flex text-yellow-400">
            {'★★★★★'.split('').map(s => <span>{s}</span>)}
          </div>
          <span class="text-white font-semibold">4.8</span>
          <span>· 194 Google reviews</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>Same-day service available</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>Upfront pricing, no surprises</span>
        </div>
      </div>
    </div>
  </div>
</section>
