---
import Layout from './Layout.astro';
import TrustBar from '../components/TrustBar.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';
import Testimonial from '../components/Testimonial.astro';
import type { Service } from '../data/services';

const BASE = import.meta.env.BASE_URL;

interface Props {
  service: Service;
}

const { service } = Astro.props;

// Get related services
const relatedServiceData = service.relatedServices
  .map(slug => services.find(s => s.slug === slug))
  .filter(Boolean) as Service[];

// Pick 2-3 relevant testimonials (just reuse general ones for demo)
const displayTestimonials = testimonials.slice(0, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.title,
  description: service.description,
  provider: {
    '@type': 'AutoRepair',
    name: 'Pre-Built Transmissions',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '80 W 500 N',
      addressLocality: 'Orem',
      addressRegion: 'UT',
      postalCode: '84057',
    },
    telephone: '+13854628458',
  },
};
---

<Layout
  title={`${service.title} | Pre-Built Transmissions — Orem, UT`}
  description={service.description.substring(0, 160)}
  ogImage={service.heroImage}
  schema={schema}
>
  <!-- Breadcrumb -->
  <BreadcrumbNav items={[
    { label: 'Services', href: `${BASE}/services/transmission-replacement/` },
    { label: service.shortTitle },
  ]} />

  <!-- Mini Hero -->
  <section class="relative py-20 overflow-hidden" style="background-color: #1B2838;">
    <div class="absolute inset-0 z-0">
      <img
        src={service.heroImage}
        alt={service.shortTitle}
        class="w-full h-full object-cover opacity-20"
        loading="eager"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(27,40,56,0.95) 0%, rgba(27,40,56,0.6) 100%);"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="inline-block px-3 py-1 rounded-full text-xs font-heading font-bold uppercase tracking-wider text-white mb-4" style="background: rgba(232,107,0,0.3); border: 1px solid rgba(232,107,0,0.5);">
          Truck Transmission Specialists
        </div>
        <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl uppercase text-white tracking-tight leading-none mb-4">
          {service.title}
        </h1>
        <p class="font-heading text-xl text-orange-400 font-semibold mb-5">{service.headline}</p>
        <p class="font-body text-gray-300 leading-relaxed mb-8">{service.description}</p>
        <div class="flex flex-wrap gap-4">
          <a href={`${BASE}/contact/`} class="btn-primary">Schedule This Service</a>
          <a href="tel:+13854628458" class="btn-secondary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            (385) 462-8458
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TrustBar -->
  <TrustBar />

  <!-- Features Grid -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-animate>
        <h2 class="section-heading mb-4">What's Included</h2>
        <p class="section-subheading mx-auto">Every {service.shortTitle.toLowerCase()} job at Pre-Built Transmissions includes:</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {service.features.map((feature, i) => (
          <div class="flex gap-4 p-6 bg-white rounded-xl shadow-sm" data-animate data-delay={i * 80}>
            <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5" style="background: rgba(232,107,0,0.1);">
              <svg class="w-5 h-5" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="font-body text-gray-700 text-sm leading-relaxed">{feature}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service FAQs -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-animate>
        <h2 class="section-heading mb-4">Common Questions</h2>
      </div>
      <div class="flex flex-col gap-3">
        {service.faqs.map((faq, i) => (
          <details class="card" data-animate data-delay={i * 100}>
            <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer select-none list-none">
              <h3 class="font-heading font-bold text-lg text-brand-steel pr-4">{faq.question}</h3>
              <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background-color: rgba(232,107,0,0.1);">
                <svg class="w-4 h-4" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 5v14M5 12h14" />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6">
              <p class="font-body text-gray-600 leading-relaxed border-t border-gray-100 pt-4">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Sample -->
  <section class="py-20 bg-brand-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10" data-animate>
        <h2 class="section-heading mb-3">What Our Customers Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {displayTestimonials.map((t, i) => (
          <div data-animate data-delay={i * 100}>
            <Testimonial testimonial={t} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServiceData.length > 0 && (
    <section class="py-20 bg-brand-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10" data-animate>
          <h2 class="section-heading mb-3">Related Services</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedServiceData.map((related, i) => (
            <a
              href={`${BASE}/services/${related.slug}/`}
              class="group card p-6 hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
              data-animate
              data-delay={i * 100}
            >
              <h3 class="font-heading font-black text-xl uppercase text-brand-steel mb-2 group-hover:text-orange-600 transition-colors">
                {related.shortTitle}
              </h3>
              <p class="font-body text-sm text-gray-600 mb-4 line-clamp-2">{related.headline}</p>
              <div class="flex items-center gap-2 font-heading font-bold text-sm uppercase tracking-wider" style="color: #E86B00;">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Bottom CTA -->
  <section class="py-16" style="background-color: #E86B00;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-black text-3xl md:text-4xl uppercase text-white tracking-tight mb-4">
        Ready to Get Your Truck Fixed?
      </h2>
      <p class="font-body text-orange-100 mb-8">
        Free 50-mile towing · Same-day service · Domestic trucks only
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${BASE}/contact/`} class="bg-white font-heading font-bold uppercase tracking-wider px-8 py-4 rounded transition-all duration-200 inline-flex items-center gap-2 hover:bg-gray-100" style="color: #E86B00;">
          Schedule Service Online
        </a>
        <a href="tel:+13854628458" class="bg-transparent border-2 border-white text-white hover:bg-white font-heading font-bold uppercase tracking-wider px-8 py-4 rounded transition-all duration-200 inline-flex items-center gap-2" style="hover:color: #E86B00;">
          Call (385) 462-8458
        </a>
      </div>
    </div>
  </section>
</Layout>
