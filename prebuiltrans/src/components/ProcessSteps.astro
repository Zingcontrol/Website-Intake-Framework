---
const steps = [
  {
    number: '01',
    title: 'Call or Tow In',
    description: 'Call (385) 462-8458 to describe your issue, or use our online form to schedule. If your truck won\'t move, we\'ll tow it free within 50 miles. No charge, no conditions.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>`,
  },
  {
    number: '02',
    title: 'Free Diagnosis',
    description: 'Our technicians perform a full live-data scan, road test, and visual inspection. We pinpoint the root cause and give you a written estimate — no surprise charges, no pressure.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    number: '03',
    title: 'We Install Your Pre-Built Unit',
    description: 'We pull your pre-built, upgraded transmission off the shelf and install it. No waiting for cores, no long rebuild queues. Most installs are completed same day.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    number: '04',
    title: 'Back on the Road',
    description: 'Road test, fluid check, final inspection — and you\'re out the door. Backed by our 1-year warranty. Your truck is back to work, often the same day you brought it in.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
  },
];
---

<section class="py-20" style="background-color: #1B2838;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14" data-animate>
      <h2 class="font-heading font-black text-4xl md:text-5xl uppercase text-white tracking-tight mb-4">
        How It Works
      </h2>
      <p class="font-body text-lg text-gray-400 max-w-xl mx-auto">
        From first call to back on the road — here's our streamlined process.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="relative flex flex-col items-center text-center" data-animate data-delay={i * 100}>
          <!-- Connector line for desktop -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-10 left-1/2 w-full h-px" style="background: linear-gradient(to right, rgba(232,107,0,0.5), rgba(232,107,0,0.1));"></div>
          )}

          <!-- Step number circle -->
          <div class="relative w-20 h-20 rounded-full flex items-center justify-center mb-5 flex-shrink-0 z-10" style="background: rgba(232,107,0,0.15); border: 2px solid rgba(232,107,0,0.5);">
            <span set:html={step.icon} style="color: #E86B00;" />
            <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full flex items-center justify-center font-heading font-black text-xs text-white" style="background-color: #E86B00;">
              {i + 1}
            </div>
          </div>

          <h3 class="font-heading font-black text-xl uppercase text-white tracking-tight mb-3">{step.title}</h3>
          <p class="font-body text-sm text-gray-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
