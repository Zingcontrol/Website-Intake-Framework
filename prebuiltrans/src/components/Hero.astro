---
const BASE = import.meta.env.BASE_URL;
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden" style="background-color: #1B2838;">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?w=1920&q=80"
      alt="Heavy duty truck on the road"
      class="w-full h-full object-cover opacity-25"
      loading="eager"
    />
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(27,40,56,0.95) 0%, rgba(27,40,56,0.75) 60%, rgba(232,107,0,0.15) 100%);"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-3xl">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-heading font-bold uppercase tracking-wider text-white mb-6" style="background: rgba(232,107,0,0.2); border: 1px solid rgba(232,107,0,0.5);">
        <span class="w-2 h-2 rounded-full animate-pulse" style="background-color: #E86B00;"></span>
        Pre-Built In Stock · Same-Day Service · Free Towing
      </div>

      <!-- Headline -->
      <h1 class="font-heading font-black text-5xl sm:text-6xl lg:text-7xl uppercase text-white leading-none tracking-tight mb-6">
        Your Truck's Transmission.<br>
        <span style="color: #E86B00;">Fixed Right. Today.</span>
      </h1>

      <!-- Subheadline -->
      <p class="font-body text-xl text-gray-300 mb-8 leading-relaxed max-w-2xl">
        We keep prebuilt, in-stock transmission units ready for Ford, Chevy/GMC, and Dodge/Ram trucks — so you get same-day service instead of waiting weeks. Plus free towing within 50 miles, 24/7 emergency line, and upgraded units that outlast OEM.
      </p>

      <!-- Stats -->
      <div class="flex flex-wrap gap-6 mb-10">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(232,107,0,0.2); border: 1px solid rgba(232,107,0,0.4);">
            <svg class="w-6 h-6" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <div class="font-heading font-black text-2xl text-white leading-none">1-Day</div>
            <div class="font-body text-sm text-gray-400">Turnaround</div>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(232,107,0,0.2); border: 1px solid rgba(232,107,0,0.4);">
            <svg class="w-6 h-6" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <div class="font-heading font-black text-2xl text-white leading-none">50mi</div>
            <div class="font-body text-sm text-gray-400">Free Towing</div>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(232,107,0,0.2); border: 1px solid rgba(232,107,0,0.4);">
            <svg class="w-6 h-6" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <div>
            <div class="font-heading font-black text-2xl text-white leading-none">Domestic</div>
            <div class="font-body text-sm text-gray-400">Trucks Only</div>
          </div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a href={`${BASE}/contact/`} class="btn-primary text-base px-8 py-4">
          Get Your Truck In Today
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:+13854628458" class="btn-secondary text-base px-8 py-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (385) 462-8458
        </a>
      </div>

      <!-- Emergency line note -->
      <p class="mt-5 font-body text-sm text-gray-400">
        24/7 Emergency Line: <a href="tel:+18333228458" class="text-orange-400 hover:text-orange-300 font-medium">(833) 322-8458</a> — Real people, day or night.
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
    <div class="w-px h-12 bg-gradient-to-b from-transparent to-orange-500 opacity-60"></div>
    <div class="w-1.5 h-1.5 rounded-full" style="background-color: #E86B00;"></div>
  </div>
</section>
