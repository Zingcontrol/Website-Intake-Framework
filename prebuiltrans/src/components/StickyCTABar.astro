---
const BASE = import.meta.env.BASE_URL;
---

<div
  id="sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 transition-all duration-300 translate-y-full"
  style="background-color: #1B2838; border-top: 2px solid #E86B00; box-shadow: 0 -4px 24px rgba(0,0,0,0.4);"
>
  <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col sm:flex-row items-center justify-between gap-3">
    <div class="text-center sm:text-left">
      <div class="font-heading font-black text-white text-base uppercase tracking-tight">Truck transmission problems?</div>
      <div class="font-body text-xs text-gray-400">Free towing · Same-day service · Domestic trucks only</div>
    </div>
    <div class="flex items-center gap-3">
      <a href="tel:+13854628458" class="btn-primary text-sm px-5 py-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call Now
      </a>
      <a href={`${BASE}/contact/`} class="btn-secondary text-sm px-5 py-2">Schedule Online</a>
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-cta');
  let shown = false;

  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 600;
    if (scrolled && !shown) {
      shown = true;
      bar?.classList.remove('translate-y-full');
    } else if (!scrolled && shown) {
      shown = false;
      bar?.classList.add('translate-y-full');
    }
  });
</script>
