---
import { faqs } from '../data/faqs';
---

<section class="py-20 bg-brand-light">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-animate>
      <h2 class="section-heading mb-4">Frequently Asked Questions</h2>
      <p class="section-subheading mx-auto">
        Everything you need to know about transmission service for your domestic truck.
      </p>
    </div>

    <div class="flex flex-col gap-3">
      {faqs.map((faq, i) => (
        <details class="card group" data-animate data-delay={Math.min(i * 50, 400)}>
          <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer select-none list-none">
            <h3 class="font-heading font-bold text-lg text-brand-steel group-open:text-orange-600 transition-colors pr-4">
              {faq.question}
            </h3>
            <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background-color: rgba(232,107,0,0.1);">
              <svg class="w-4 h-4" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6">
            <p class="font-body text-gray-600 leading-relaxed border-t border-gray-100 pt-4">
              {faq.answer}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
