---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { services } from '../data/services';

const BASE = import.meta.env.BASE_URL;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'AutoRepair',
      '@id': 'https://zingcontrol.github.io/Website-Intake-Framework/prebuiltrans/#business',
      name: 'Pre-Built Transmissions',
      alternateName: 'Truck Transmission Specialists',
      description:
        'Domestic truck transmission specialists in Orem, UT. Prebuilt in-stock units for Ford, Chevy/GMC & Dodge/Ram. Same-day service, free 50-mile towing, 1-year warranty.',
      url: 'https://zingcontrol.github.io/Website-Intake-Framework/prebuiltrans/',
      telephone: '+13854628458',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '80 W 500 N',
        addressLocality: 'Orem',
        addressRegion: 'UT',
        postalCode: '84057',
        addressCountry: 'US',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 40.2969,
        longitude: -111.6946,
      },
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
          opens: '08:00',
          closes: '17:00',
        },
      ],
      priceRange: '$$',
      image: 'https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?w=1200&q=80',
      areaServed: {
        '@type': 'GeoCircle',
        geoMidpoint: {
          '@type': 'GeoCoordinates',
          latitude: 40.2969,
          longitude: -111.6946,
        },
        geoRadius: '80470',
      },
    },
    {
      '@type': 'LocalBusiness',
      '@id': 'https://zingcontrol.github.io/Website-Intake-Framework/prebuiltrans/#local',
      name: 'Pre-Built Transmissions',
      telephone: '+13854628458',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '80 W 500 N',
        addressLocality: 'Orem',
        addressRegion: 'UT',
        postalCode: '84057',
        addressCountry: 'US',
      },
    },
  ],
};
---

<Layout
  title="Pre-Built Transmissions | Truck Transmission Specialists — Orem, UT"
  description="Orem's domestic truck transmission specialists. Prebuilt in-stock units for Ford, Chevy/GMC & Dodge/Ram — same-day service, free 50-mile towing, 1-year warranty. Call (385) 462-8458."
  schema={schema}
>
  <!-- 1. Announcement Bar -->
  <AnnouncementBar />

  <!-- 2. Hero -->
  <Hero />

  <!-- 3. TrustBar -->
  <TrustBar />

  <!-- 4. Why Pre-Built Section -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div data-animate>
          <div class="inline-block px-3 py-1 rounded-full text-xs font-heading font-bold uppercase tracking-wider mb-4" style="background: rgba(232,107,0,0.1); color: #C55A00;">
            Why Pre-Built Wins
          </div>
          <h2 class="section-heading mb-6">Prebuilt vs. Rebuilt vs. Dealer — Why Our Way Is Faster</h2>
          <p class="font-body text-gray-600 leading-relaxed mb-6">
            When your truck transmission fails, you have three options. Understanding the difference helps you see why our prebuilt approach consistently wins for working truck owners.
          </p>

          <div class="flex flex-col gap-4">
            <!-- Comparison rows -->
            <div class="flex gap-4 p-4 rounded-xl bg-white shadow-sm border-l-4" style="border-color: #E86B00;">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background-color: #E86B00;">
                  <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
              </div>
              <div>
                <div class="font-heading font-bold text-brand-steel uppercase tracking-tight">Our Prebuilt Unit</div>
                <div class="font-body text-sm text-gray-600">Built ahead of time, tested, upgraded beyond OEM. Ready to install the day you arrive. Typical turnaround: same day or next morning.</div>
              </div>
            </div>

            <div class="flex gap-4 p-4 rounded-xl bg-white shadow-sm border-l-4 border-gray-200">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 rounded-full flex items-center justify-center bg-gray-200">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <div class="font-heading font-bold text-gray-500 uppercase tracking-tight">Standard Rebuild</div>
                <div class="font-body text-sm text-gray-400">Starts when you drop off your truck. Parts ordered, disassembled, rebuilt, reassembled. Typical wait: 3–7 business days minimum.</div>
              </div>
            </div>

            <div class="flex gap-4 p-4 rounded-xl bg-white shadow-sm border-l-4 border-gray-200">
              <div class="flex-shrink-0">
                <div class="w-8 h-8 rounded-full flex items-center justify-center bg-gray-200">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
              <div>
                <div class="font-heading font-bold text-gray-500 uppercase tracking-tight">Dealer Service</div>
                <div class="font-body text-sm text-gray-400">Generalist technicians, OEM parts only, premium pricing. Often 1–3 week waits for parts to arrive. Highest cost, stock-spec performance.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="relative" data-animate data-delay="200">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1619642751034-765dfdf7c58e?w=800&q=80"
              alt="Prebuilt transmission unit ready for installation"
              class="w-full h-[420px] object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(27,40,56,0.8) 0%, transparent 50%);"></div>
            <div class="absolute bottom-6 left-6 right-6">
              <div class="font-heading font-black text-2xl uppercase text-white mb-1">Prebuilt. Upgraded. Ready.</div>
              <div class="font-body text-sm text-gray-300">Every unit built beyond OEM spec before your truck arrives</div>
            </div>
          </div>
          <!-- Floating stat -->
          <div class="absolute -top-6 -right-6 w-28 h-28 rounded-full flex flex-col items-center justify-center text-center shadow-xl" style="background-color: #E86B00;">
            <div class="font-heading font-black text-white text-2xl leading-none">1</div>
            <div class="font-heading font-bold text-white text-xs uppercase leading-none mt-1">Day<br>Turnaround</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. ProcessSteps -->
  <ProcessSteps />

  <!-- 6. Services Grid -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-animate>
        <h2 class="section-heading mb-4">Our Services</h2>
        <p class="section-subheading mx-auto">
          Everything your domestic truck's transmission needs — under one roof, by specialists.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <ServiceCard service={service} delay={i * 80} />
        ))}
      </div>
    </div>
  </section>

  <!-- 7. Testimonials -->
  <TestimonialCarousel />

  <!-- 8. Domestic Trucks Only Section -->
  <section class="py-20" style="background-color: #1B2838;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14" data-animate>
        <div class="inline-block px-3 py-1 rounded-full text-xs font-heading font-bold uppercase tracking-wider mb-4" style="background: rgba(232,107,0,0.2); border: 1px solid rgba(232,107,0,0.4); color: #FF8C2A;">
          Specialization Matters
        </div>
        <h2 class="font-heading font-black text-4xl md:text-5xl uppercase text-white tracking-tight mb-4">
          Domestic Trucks Only
        </h2>
        <p class="font-body text-gray-400 max-w-2xl mx-auto">
          We don't try to be everything to everyone. We work on Ford, Chevrolet/GMC, and Dodge/Ram trucks — and nothing else. That focus means deeper knowledge, better parts inventory, and faster turnarounds for your truck.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <!-- Ford -->
        <div class="rounded-2xl overflow-hidden" style="background: rgba(42,58,74,0.8); border: 1px solid rgba(168,178,188,0.2);" data-animate>
          <div class="h-48 relative overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=600&q=80"
              alt="Ford truck transmission service"
              class="w-full h-full object-cover opacity-60"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="font-heading font-black text-4xl uppercase text-white tracking-widest" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8);">FORD</div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading font-black text-xl uppercase text-white mb-2">Ford Trucks</h3>
            <p class="font-body text-sm text-gray-400 leading-relaxed">F-150, F-250, F-350, Super Duty — all generations. We stock prebuilt units for Ford's most common transmission platforms including 4R100, 5R110, 6R140, and more.</p>
          </div>
        </div>

        <!-- Chevy/GMC -->
        <div class="rounded-2xl overflow-hidden" style="background: rgba(42,58,74,0.8); border: 1px solid rgba(168,178,188,0.2);" data-animate data-delay="100">
          <div class="h-48 relative overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?w=600&q=80"
              alt="Chevy GMC truck transmission service"
              class="w-full h-full object-cover opacity-60"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="font-heading font-black text-4xl uppercase text-white tracking-widest" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8);">CHEVY / GMC</div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading font-black text-xl uppercase text-white mb-2">Chevrolet &amp; GMC Trucks</h3>
            <p class="font-body text-sm text-gray-400 leading-relaxed">Silverado 1500–3500, Sierra, Colorado/Canyon. From the 4L60E to the 10-speed 10L90, we know GM truck transmissions inside and out.</p>
          </div>
        </div>

        <!-- Dodge/Ram -->
        <div class="rounded-2xl overflow-hidden" style="background: rgba(42,58,74,0.8); border: 1px solid rgba(168,178,188,0.2);" data-animate data-delay="200">
          <div class="h-48 relative overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?w=600&q=80"
              alt="Dodge Ram truck transmission service"
              class="w-full h-full object-cover opacity-60"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="font-heading font-black text-4xl uppercase text-white tracking-widest" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8);">DODGE / RAM</div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-heading font-black text-xl uppercase text-white mb-2">Dodge &amp; Ram Trucks</h3>
            <p class="font-body text-sm text-gray-400 leading-relaxed">Ram 1500, 2500, 3500 — including Cummins diesel applications. We specialize in the 45RFE, 65RFE, 68RFE, and Ram TorqueFlite transmissions.</p>
          </div>
        </div>
      </div>

      <!-- No imports callout -->
      <div class="rounded-2xl p-8 text-center" style="background: rgba(232,107,0,0.08); border: 1px solid rgba(232,107,0,0.3);" data-animate>
        <div class="text-3xl mb-3">🚫</div>
        <h3 class="font-heading font-black text-2xl uppercase text-white mb-2">No Import Vehicles. No Sideline Jobs.</h3>
        <p class="font-body text-gray-400 max-w-xl mx-auto">
          We don't service Toyota, Honda, Nissan, or any foreign-brand vehicles. We also don't do engine work, brakes, or any other repair. Transmissions, domestic trucks, done right — that's it. That focus is why we're better at it than anyone else in Utah Valley.
        </p>
      </div>
    </div>
  </section>

  <!-- 9. FAQAccordion -->
  <FAQAccordion />

  <!-- 10. Final CTA Section -->
  <section class="py-16" style="background-color: #E86B00;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-black text-3xl md:text-4xl uppercase text-white tracking-tight mb-4">
        Your Truck Can't Wait. Neither Can You.
      </h2>
      <p class="font-body text-orange-100 text-lg mb-8 max-w-2xl mx-auto">
        Call now or schedule online. We'll get your Ford, Chevy, or Dodge truck's transmission fixed — right, fast, and with a warranty.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${BASE}/contact/`} class="bg-white font-heading font-bold uppercase tracking-wider text-base px-10 py-4 rounded transition-all duration-200 inline-flex items-center gap-2 hover:bg-gray-100" style="color: #E86B00;">
          Schedule Service Online
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:+13854628458" class="bg-transparent border-2 border-white text-white font-heading font-bold uppercase tracking-wider text-base px-10 py-4 rounded transition-all duration-200 inline-flex items-center gap-2 hover:bg-white/10">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (385) 462-8458
        </a>
      </div>
      <p class="font-body text-orange-200 text-sm mt-5">
        24/7 Emergency Line: <a href="tel:+18333228458" class="font-medium underline hover:no-underline">(833) 322-8458</a>
      </p>
    </div>
  </section>
</Layout>
