---
import Layout from '../layouts/Layout.astro';
import TrustBar from '../components/TrustBar.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';

const BASE = import.meta.env.BASE_URL;
---

<Layout
  title="Contact & Schedule Service | Pre-Built Transmissions — Orem, UT"
  description="Schedule transmission service for your Ford, Chevy/GMC, or Dodge/Ram truck. Free towing within 50 miles. Call (385) 462-8458 or use our online form."
>
  <BreadcrumbNav items={[{ label: 'Contact & Schedule' }]} />

  <!-- Page Hero -->
  <section class="py-16 relative overflow-hidden" style="background-color: #1B2838;">
    <div class="absolute inset-0 z-0 opacity-10">
      <img
        src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80"
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-block px-3 py-1 rounded-full text-xs font-heading font-bold uppercase tracking-wider mb-4" style="background: rgba(232,107,0,0.2); border: 1px solid rgba(232,107,0,0.5); color: #FF8C2A;">
        Free Towing · Same-Day Service
      </div>
      <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl uppercase text-white tracking-tight mb-4">
        Get Your Truck In Today
      </h1>
      <p class="font-body text-gray-400 text-lg max-w-xl mx-auto">
        Fill out the form below or call us directly. We'll confirm your unit is in stock and get you scheduled fast.
      </p>
    </div>
  </section>

  <TrustBar />

  <!-- Contact Content -->
  <section class="py-20 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-md p-8" data-animate>
            <h2 class="font-heading font-black text-3xl uppercase text-brand-steel tracking-tight mb-2">Schedule Service Online</h2>
            <p class="font-body text-gray-500 text-sm mb-8">We'll get back to you within 1 business hour during shop hours (Mon–Fri 8am–5pm).</p>

            <form id="contact-form" class="flex flex-col gap-6" novalidate>
              <!-- Name & Phone row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div class="flex flex-col gap-1.5">
                  <label for="name" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                    Your Name <span class="text-orange-600">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="John Smith"
                    required
                    class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors"
                  />
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="phone" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                    Phone Number <span class="text-orange-600">*</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="(801) 555-0100"
                    required
                    class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors"
                  />
                </div>
              </div>

              <!-- Email -->
              <div class="flex flex-col gap-1.5">
                <label for="email" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                  Email Address
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors"
                />
              </div>

              <!-- Truck Make & Model -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div class="flex flex-col gap-1.5">
                  <label for="truck-make" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                    Truck Make <span class="text-orange-600">*</span>
                  </label>
                  <select
                    id="truck-make"
                    name="truck-make"
                    required
                    class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors bg-white"
                  >
                    <option value="" disabled selected>Select make...</option>
                    <option value="ford">Ford</option>
                    <option value="chevy">Chevrolet</option>
                    <option value="gmc">GMC</option>
                    <option value="dodge">Dodge / Ram</option>
                    <option value="other">Other (we may not be able to help)</option>
                  </select>
                </div>
                <div class="flex flex-col gap-1.5">
                  <label for="truck-model" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                    Year &amp; Model <span class="text-orange-600">*</span>
                  </label>
                  <input
                    type="text"
                    id="truck-model"
                    name="truck-model"
                    placeholder="e.g. 2018 F-250 Super Duty"
                    required
                    class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors"
                  />
                </div>
              </div>

              <!-- Service Type -->
              <div class="flex flex-col gap-1.5">
                <label for="service-type" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                  Service Needed <span class="text-orange-600">*</span>
                </label>
                <select
                  id="service-type"
                  name="service-type"
                  required
                  class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors bg-white"
                >
                  <option value="" disabled selected>Select service...</option>
                  <option value="replacement">Transmission Replacement (Prebuilt)</option>
                  <option value="rebuild">Transmission Rebuild</option>
                  <option value="diagnostics">Diagnostics / Inspection</option>
                  <option value="fluid">Fluid Service</option>
                  <option value="towing">Free Towing Request</option>
                  <option value="emergency">Emergency Service</option>
                  <option value="not-sure">Not Sure — Need Advice</option>
                </select>
              </div>

              <!-- Needs Towing -->
              <div class="flex flex-col gap-3">
                <span class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">Does your truck need towing?</span>
                <div class="flex gap-6">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="needs-towing" value="yes" class="w-4 h-4 accent-orange-500" />
                    <span class="font-body text-sm text-gray-700">Yes — truck won't move</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="needs-towing" value="no" class="w-4 h-4 accent-orange-500" />
                    <span class="font-body text-sm text-gray-700">No — I can drive it in</span>
                  </label>
                </div>
              </div>

              <!-- Issue Description -->
              <div class="flex flex-col gap-1.5">
                <label for="description" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                  Describe the Problem <span class="text-orange-600">*</span>
                </label>
                <textarea
                  id="description"
                  name="description"
                  rows="4"
                  required
                  placeholder="Tell us what's happening with your truck's transmission — when it started, what symptoms you're experiencing, any warning lights, etc."
                  class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors resize-vertical"
                ></textarea>
              </div>

              <!-- Preferred Contact Time -->
              <div class="flex flex-col gap-1.5">
                <label for="contact-time" class="font-heading font-bold text-sm uppercase tracking-wider text-brand-steel">
                  Best Time to Call
                </label>
                <select
                  id="contact-time"
                  name="contact-time"
                  class="px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-orange-500 focus:outline-none font-body text-sm transition-colors bg-white"
                >
                  <option value="asap">ASAP — call me anytime</option>
                  <option value="morning">Morning (8am–noon)</option>
                  <option value="afternoon">Afternoon (noon–5pm)</option>
                </select>
              </div>

              <!-- Submit -->
              <button type="submit" class="btn-primary justify-center text-center text-base px-8 py-4">
                Submit Service Request
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </button>

              <!-- Disclaimer -->
              <p class="font-body text-xs text-gray-400 text-center">
                This is a demo contact form. For immediate assistance, call <a href="tel:+13854628458" class="text-orange-500 hover:underline">(385) 462-8458</a>.
              </p>
            </form>

            <!-- Success message (hidden by default) -->
            <div id="form-success" class="hidden text-center py-12">
              <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background: rgba(232,107,0,0.1);">
                <svg class="w-8 h-8" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="font-heading font-black text-2xl uppercase text-brand-steel mb-2">Request Received!</h3>
              <p class="font-body text-gray-500">We'll call you back within 1 business hour. If it's urgent, call us directly at <a href="tel:+13854628458" class="text-orange-500 font-medium">(385) 462-8458</a>.</p>
            </div>
          </div>
        </div>

        <!-- Contact Sidebar -->
        <div class="flex flex-col gap-6">

          <!-- Main phone -->
          <div class="bg-white rounded-2xl shadow-md p-6" data-animate data-delay="100">
            <h3 class="font-heading font-black text-xl uppercase text-brand-steel tracking-tight mb-4">Call Us Directly</h3>

            <a href="tel:+13854628458" class="flex items-start gap-4 mb-5 group">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: #E86B00;">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="font-heading font-black text-2xl text-brand-steel group-hover:text-orange-600 transition-colors">(385) 462-8458</div>
                <div class="font-body text-sm text-gray-500">Main Shop Line · Mon–Fri 8am–5pm</div>
              </div>
            </a>

            <div class="border-t border-gray-100 pt-5">
              <div class="font-heading font-bold text-xs uppercase tracking-wider text-gray-400 mb-3">24/7 Emergency Line</div>
              <a href="tel:+18333228458" class="flex items-center gap-3 group">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: rgba(232,107,0,0.1); border: 1px solid rgba(232,107,0,0.3);">
                  <svg class="w-5 h-5" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                </div>
                <div>
                  <div class="font-heading font-black text-xl text-brand-steel group-hover:text-orange-600 transition-colors">(833) 322-8458</div>
                  <div class="font-body text-xs text-gray-500">Available 24 hours · 7 days a week</div>
                </div>
              </a>
            </div>
          </div>

          <!-- Hours -->
          <div class="bg-white rounded-2xl shadow-md p-6" data-animate data-delay="150">
            <h3 class="font-heading font-black text-xl uppercase text-brand-steel tracking-tight mb-4">Shop Hours</h3>
            <ul class="flex flex-col gap-2">
              <li class="flex justify-between items-center py-1.5 border-b border-gray-50">
                <span class="font-body text-sm text-gray-500">Monday</span>
                <span class="font-heading font-bold text-sm text-brand-steel">8:00 AM – 5:00 PM</span>
              </li>
              <li class="flex justify-between items-center py-1.5 border-b border-gray-50">
                <span class="font-body text-sm text-gray-500">Tuesday</span>
                <span class="font-heading font-bold text-sm text-brand-steel">8:00 AM – 5:00 PM</span>
              </li>
              <li class="flex justify-between items-center py-1.5 border-b border-gray-50">
                <span class="font-body text-sm text-gray-500">Wednesday</span>
                <span class="font-heading font-bold text-sm text-brand-steel">8:00 AM – 5:00 PM</span>
              </li>
              <li class="flex justify-between items-center py-1.5 border-b border-gray-50">
                <span class="font-body text-sm text-gray-500">Thursday</span>
                <span class="font-heading font-bold text-sm text-brand-steel">8:00 AM – 5:00 PM</span>
              </li>
              <li class="flex justify-between items-center py-1.5 border-b border-gray-50">
                <span class="font-body text-sm text-gray-500">Friday</span>
                <span class="font-heading font-bold text-sm text-brand-steel">8:00 AM – 5:00 PM</span>
              </li>
              <li class="flex justify-between items-center py-1.5 border-b border-gray-50">
                <span class="font-body text-sm text-gray-500">Saturday</span>
                <span class="font-heading font-medium text-sm text-gray-400">Closed</span>
              </li>
              <li class="flex justify-between items-center py-1.5">
                <span class="font-body text-sm text-gray-500">Sunday</span>
                <span class="font-heading font-medium text-sm text-gray-400">Closed</span>
              </li>
            </ul>
            <div class="mt-4 p-3 rounded-lg" style="background: rgba(232,107,0,0.08); border: 1px solid rgba(232,107,0,0.25);">
              <p class="font-body text-xs text-gray-600">
                <strong class="font-heading" style="color: #E86B00;">After hours?</strong> Call our 24/7 emergency line at <a href="tel:+18333228458" class="text-orange-600 hover:underline">(833) 322-8458</a>
              </p>
            </div>
          </div>

          <!-- Address -->
          <div class="bg-white rounded-2xl shadow-md p-6" data-animate data-delay="200">
            <h3 class="font-heading font-black text-xl uppercase text-brand-steel tracking-tight mb-4">Our Location</h3>
            <div class="flex items-start gap-3 mb-4">
              <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="none" stroke="#E86B00" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <div>
                <p class="font-body text-sm text-gray-700 font-medium">80 W 500 N</p>
                <p class="font-body text-sm text-gray-700">Orem, UT 84057</p>
              </div>
            </div>
            <a
              href="https://maps.google.com/?q=80+W+500+N+Orem+UT+84057"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 font-heading font-bold text-sm uppercase tracking-wider transition-colors"
              style="color: #E86B00;"
            >
              Get Directions
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>

          <!-- Free Towing callout -->
          <div class="rounded-2xl p-6 text-white" style="background-color: #E86B00;" data-animate data-delay="250">
            <div class="font-heading font-black text-2xl uppercase mb-2">Free 50-Mile Towing</div>
            <p class="font-body text-sm text-orange-100 mb-4">
              If your truck won't drive, we'll come get it — no charge, no conditions, within 50 miles of Orem.
            </p>
            <a href="tel:+13854628458" class="inline-flex items-center gap-2 bg-white font-heading font-bold text-sm uppercase tracking-wider px-5 py-2.5 rounded transition-colors hover:bg-orange-50" style="color: #E86B00;">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Request Tow Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successDiv = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // Demo form — just show success state
    if (form && successDiv) {
      form.style.display = 'none';
      successDiv.classList.remove('hidden');
    }
  });
</script>
