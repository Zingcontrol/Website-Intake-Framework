---
import { faqs } from '../data/faqs';
---

<section id="faq" class="py-20 md:py-28 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14 animate-on-scroll">
      <span class="inline-block px-3 py-1 rounded-full bg-brand-teal/10 text-brand-teal text-sm font-semibold mb-4">
        Common Questions
      </span>
      <h2 class="section-heading mb-4">
        Answers Before the Call
      </h2>
      <p class="section-subheading max-w-2xl mx-auto">
        We get the same questions every week. Here are honest answers — no sales spin.
      </p>
    </div>

    <!-- FAQ items -->
    <div class="space-y-3 animate-on-scroll">
      {faqs.map((faq, index) => (
        <div
          class="faq-item border border-gray-200 rounded-xl overflow-hidden bg-white hover:border-brand-teal/40 transition-colors"
          data-faq-id={faq.id}
        >
          <button
            class="w-full flex items-start justify-between gap-4 px-6 py-5 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-teal focus-visible:ring-inset group"
            aria-expanded="false"
            aria-controls={`faq-answer-${faq.id}`}
            id={`faq-btn-${faq.id}`}
          >
            <span class="font-semibold text-brand-navy text-[0.95rem] leading-snug group-hover:text-brand-teal transition-colors">
              {faq.question}
            </span>
            <svg
              class="faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5 transition-transform duration-300 group-hover:text-brand-teal"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            class="faq-content"
            id={`faq-answer-${faq.id}`}
            role="region"
            aria-labelledby={`faq-btn-${faq.id}`}
          >
            <div class="px-6 pb-6 text-gray-600 text-sm leading-relaxed">
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const btn = item.querySelector('button');
    const content = item.querySelector('.faq-content');

    btn?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item.open').forEach((openItem) => {
        openItem.classList.remove('open');
        openItem.querySelector('.faq-content')?.classList.remove('open');
        openItem.querySelector('button')?.setAttribute('aria-expanded', 'false');
      });

      // Toggle clicked
      if (!isOpen) {
        item.classList.add('open');
        content?.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
