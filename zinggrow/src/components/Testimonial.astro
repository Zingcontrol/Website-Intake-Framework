---
export interface Props {
  name: string;
  title: string;
  business: string;
  industry: string;
  quote: string;
  rating: number;
  previousTool: string;
}

const { name, title, business, industry, quote, rating, previousTool } = Astro.props;

// Generate initials for avatar
const initials = name.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase();

// Deterministic color from name
const colors = ['#1A7A8A', '#F5820A', '#1B2E45', '#D4700A', '#2A9BAD', '#0D1B2A'];
const colorIndex = name.charCodeAt(0) % colors.length;
const avatarColor = colors[colorIndex];
---

<div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col h-full">
  <!-- Stars -->
  <div class="flex gap-1 mb-5">
    {Array.from({ length: rating }).map(() => (
      <svg class="w-5 h-5 text-brand-orange" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>

  <!-- Quote -->
  <blockquote class="text-gray-700 text-[0.95rem] leading-relaxed flex-1 mb-6">
    <span class="text-brand-orange font-black text-3xl leading-none mr-1">"</span>{quote}<span class="text-brand-orange font-black text-3xl leading-none ml-1">"</span>
  </blockquote>

  <!-- Footer -->
  <div class="flex items-center justify-between border-t border-gray-100 pt-5">
    <div class="flex items-center gap-3">
      <!-- Avatar circle with initials -->
      <div
        class="w-11 h-11 rounded-full flex items-center justify-center text-white font-bold text-sm flex-shrink-0"
        style={`background-color: ${avatarColor};`}
      >
        {initials}
      </div>
      <div>
        <div class="font-semibold text-brand-navy text-sm leading-tight">{name}</div>
        <div class="text-gray-500 text-xs">{title}, {business}</div>
      </div>
    </div>
    <div class="text-right hidden sm:block">
      <div class="text-xs text-gray-400 leading-tight">Switched from</div>
      <div class="text-xs font-medium text-gray-500">{previousTool}</div>
    </div>
  </div>
</div>
