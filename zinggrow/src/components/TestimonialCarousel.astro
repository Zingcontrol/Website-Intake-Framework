---
import { testimonials } from '../data/testimonials';
import Testimonial from './Testimonial.astro';

const base = import.meta.env.BASE_URL;
---

<section class="py-20 md:py-28 bg-brand-light overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center max-w-3xl mx-auto mb-14 animate-on-scroll">
      <span class="inline-block px-3 py-1 rounded-full bg-brand-orange/10 text-brand-orange text-sm font-semibold mb-4">
        Real Customer Stories
      </span>
      <h2 class="section-heading mb-4">
        Small Business Owners Who Made<br class="hidden sm:block" /> the Switch
      </h2>
      <p class="section-subheading">
        They were frustrated with self-serve platforms, disconnected tools, and chatbot support. Here's what happened when they found a team that actually shows up.
      </p>
    </div>

    <!-- Carousel wrapper -->
    <div class="relative">
      <!-- Cards container -->
      <div id="testimonial-track" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div
            class="testimonial-card animate-on-scroll"
            style={`animation-delay: ${i * 0.1}s;`}
          >
            <Testimonial
              name={t.name}
              title={t.title}
              business={t.business}
              industry={t.industry}
              quote={t.quote}
              rating={t.rating}
              previousTool={t.previousTool}
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 animate-on-scroll">
      <p class="text-gray-500 text-sm mb-4">Join hundreds of small businesses that switched to a platform with people behind it.</p>
      <a
        href={`${base}/demo`}
        class="inline-flex items-center gap-2 btn-primary text-base px-7 py-3.5"
      >
        Schedule Your Free Demo
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
