---
const base = import.meta.env.BASE_URL;
---

<div id="announcement-bar" class="relative bg-brand-orange text-white text-sm font-medium py-2.5 px-4 text-center">
  <span class="inline-flex flex-wrap items-center justify-center gap-x-2 gap-y-1">
    <span class="font-semibold">🎉 Limited Time:</span>
    <span>Free 30-Day Trial + White-Glove Onboarding — Only a Few Spots Left This Month.</span>
    <a
      href={`${base}/demo`}
      class="underline underline-offset-2 font-semibold hover:opacity-80 transition-opacity whitespace-nowrap"
    >
      Reserve Your Spot →
    </a>
  </span>
  <button
    id="close-announcement"
    aria-label="Close announcement"
    class="absolute right-3 top-1/2 -translate-y-1/2 p-1 rounded hover:bg-white/20 transition-colors"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<script>
  const bar = document.getElementById('announcement-bar');
  const closeBtn = document.getElementById('close-announcement');
  closeBtn?.addEventListener('click', () => {
    bar?.classList.add('hidden');
    try { sessionStorage.setItem('ann-closed', '1'); } catch {}
  });
  try {
    if (sessionStorage.getItem('ann-closed') === '1') {
      bar?.classList.add('hidden');
    }
  } catch {}
</script>
