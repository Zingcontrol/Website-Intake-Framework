---
import Layout from '../layouts/Layout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import PlatformFeatures from '../components/PlatformFeatures.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Footer from '../components/Footer.astro';
import StickyCTABar from '../components/StickyCTABar.astro';
import ScrollAnimator from '../components/ScrollAnimator.astro';

const base = import.meta.env.BASE_URL;

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'ZingGrow',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      description:
        'All-in-one CRM, email & SMS automation, appointment scheduling, review management, and analytics platform for small businesses — with human onboarding and ongoing support.',
      url: 'https://zinggrow.com',
      offers: {
        '@type': 'Offer',
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
        description: 'Monthly and annual subscription plans available',
      },
      featureList: [
        'CRM & Pipeline Management',
        'Email & SMS Automation',
        'Appointment Scheduling',
        'Review Management',
        'Website & Funnel Builder',
        'Reporting & Analytics',
        'Human Onboarding Support',
        'Ongoing Human Support',
      ],
    },
    {
      '@type': 'LocalBusiness',
      name: 'Zing Business Systems',
      alternateName: 'ZingGrow',
      legalName: 'Summit Advertising LLC',
      description:
        'Veteran-owned small business CRM and marketing automation platform. Founded in 2002, providing 24 years of hands-on support to small businesses nationwide.',
      url: 'https://zinggrow.com',
      telephone: '+18778069464',
      foundingDate: '2002',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '1090 N 960 W',
        addressLocality: 'Orem',
        addressRegion: 'UT',
        postalCode: '84057',
        addressCountry: 'US',
      },
      founder: {
        '@type': 'Person',
        name: 'Matt Kallunki',
      },
    },
  ],
};
---

<Layout
  title="ZingGrow — The CRM Built for Small Business, With Real People Behind It"
  description="Founded 2002. Veteran-owned. All-in-one CRM, automation, scheduling, and reviews — with human onboarding and ongoing support that other platforms skip. Try free for 30 days."
  schema={schema}
>
  <AnnouncementBar />
  <Header />
  <main>

    <!-- 1. Hero -->
    <Hero />

    <!-- 2. TrustBar -->
    <TrustBar />

    <!-- 3. Why Zing Is Different -->
    <section id="why-zing" class="py-20 md:py-28 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">

          <!-- Left: copy -->
          <div class="animate-on-scroll-left">
            <span class="inline-block px-3 py-1 rounded-full bg-brand-orange/10 text-brand-orange text-sm font-semibold mb-4">
              Why ZingGrow Is Different
            </span>
            <h2 class="text-3xl md:text-4xl font-black text-brand-navy leading-tight mb-6">
              We Are Not Just a Platform.<br />
              <span class="text-brand-orange">We Are a 24-Year Partner.</span>
            </h2>
            <div class="space-y-5 text-gray-600 leading-relaxed">
              <p>
                Founded in 2002 and veteran-owned, Zing Business Systems has spent more than two decades helping small businesses compete with companies three times their size. We have seen platforms come and go, watched trends cycle, and outlasted dozens of competitors.
              </p>
              <p>
                Most CRM companies give you a login and a help center. We give you a person — one who knows your name, understands your business, and picks up when you call. That is not a feature. That is a fundamental difference in how we operate.
              </p>
              <p>
                ZingGrow brings together everything a small business needs to capture leads, nurture relationships, book appointments, collect reviews, and track growth — in one platform, at one price, with one team behind it all.
              </p>
            </div>

            <!-- Credentialing bullets -->
            <div class="mt-8 space-y-3">
              {[
                { icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', text: 'Founded 2002 — 24 years in business, not a 2-year-old startup' },
                { icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9', text: 'Veteran-owned — genuine American small business roots' },
                { icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', text: 'Human team assigned to every account from day one' },
                { icon: 'M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z', text: 'All-in-one platform — one bill, not five separate subscriptions' },
              ].map(item => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-brand-teal flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                  </svg>
                  <span class="text-gray-700 text-sm">{item.text}</span>
                </div>
              ))}
            </div>

            <div class="mt-8">
              <a
                href={`${base}/demo`}
                class="btn-primary text-base px-7 py-3.5"
              >
                Schedule a Free Demo
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Right: image with overlay cards -->
          <div class="relative animate-on-scroll-right">
            <div class="rounded-2xl overflow-hidden shadow-xl">
              <img
                src="https://images.unsplash.com/photo-1531482615713-2afd69097998?w=800&auto=format&fit=crop&q=80"
                alt="Small business team reviewing growth data together"
                class="w-full h-80 md:h-[460px] object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0 rounded-2xl" style="background: linear-gradient(135deg, rgba(13,27,42,0.3) 0%, transparent 60%);"></div>
            </div>

            <!-- Overlay stat cards -->
            <div class="absolute top-6 left-6 bg-white rounded-xl p-4 shadow-lg">
              <div class="text-brand-orange font-black text-3xl leading-none">24</div>
              <div class="text-gray-600 text-xs font-medium mt-1">Years in<br/>Business</div>
            </div>

            <div class="absolute bottom-6 right-6 bg-brand-navy rounded-xl p-4 shadow-lg text-white max-w-[180px]">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
                <span class="text-xs font-semibold text-green-400">Live Support</span>
              </div>
              <div class="text-sm font-semibold leading-snug">Real humans answering the phone — right now.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. Platform Features -->
    <PlatformFeatures />

    <!-- 5. The Human Difference -->
    <section id="support" class="py-20 md:py-28" style="background-color: #0D1B2A;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-14 items-center">

          <!-- Left: image -->
          <div class="animate-on-scroll-left order-2 lg:order-1">
            <div class="rounded-2xl overflow-hidden shadow-xl border border-white/10">
              <img
                src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&auto=format&fit=crop&q=80"
                alt="ZingGrow support specialist helping a small business owner on a call"
                class="w-full h-72 md:h-[420px] object-cover"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Right: copy -->
          <div class="order-1 lg:order-2 animate-on-scroll-right">
            <span class="inline-block px-3 py-1 rounded-full bg-brand-orange/20 text-brand-orange-light text-sm font-semibold mb-4">
              The Human Difference
            </span>
            <h2 class="text-3xl md:text-4xl font-black text-white leading-tight mb-6">
              The Part Most Platforms<br />
              <span class="text-brand-orange">Forgot to Build</span>
            </h2>
            <p class="text-white/65 leading-relaxed mb-6">
              Every CRM platform promises to "transform your business." Most of them send you a welcome email, a link to a YouTube tutorial library, and a chatbot that apologizes when it can't find your answer.
            </p>
            <p class="text-white/65 leading-relaxed mb-8">
              Zing is built differently. When you sign up, a real onboarding specialist is assigned to your account within 24 hours. They get on a call, learn how you work, migrate your data, build your first automations, and train your team. And when you need help three months later, you call the same number and reach people who already know your setup.
            </p>

            <!-- Three columns: what you get -->
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
              {[
                {
                  title: 'Dedicated Specialist',
                  desc: 'Your own onboarding contact, not a random support queue',
                  icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
                },
                {
                  title: 'Done-With-You Setup',
                  desc: 'We build your workflows, migrate data, and run first campaigns with you',
                  icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
                },
                {
                  title: 'Proactive Check-Ins',
                  desc: 'Quarterly reviews and strategy calls — we reach out to you',
                  icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
                },
              ].map(item => (
                <div class="bg-white/5 border border-white/10 rounded-xl p-4">
                  <div class="w-8 h-8 rounded-lg bg-brand-orange/20 flex items-center justify-center mb-3">
                    <svg class="w-4 h-4 text-brand-orange-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                    </svg>
                  </div>
                  <div class="text-white font-semibold text-sm mb-1">{item.title}</div>
                  <div class="text-white/50 text-xs leading-relaxed">{item.desc}</div>
                </div>
              ))}
            </div>

            <a
              href={`${base}/demo`}
              class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-brand-orange text-white font-bold text-base hover:bg-brand-orange-dark transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
            >
              Meet Your Future Support Team
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. Testimonials -->
    <TestimonialCarousel />

    <!-- 7. All-in-One comparison table -->
    <section id="pricing" class="py-20 md:py-28 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14 animate-on-scroll">
          <span class="inline-block px-3 py-1 rounded-full bg-brand-teal/10 text-brand-teal text-sm font-semibold mb-4">
            The Math Checks Out
          </span>
          <h2 class="section-heading mb-4">
            All-in-One Means<br class="hidden sm:block" /> <em class="not-italic text-brand-orange">All</em>-in-One
          </h2>
          <p class="section-subheading max-w-2xl mx-auto">
            Most small businesses are cobbling together 4–6 separate tools and paying for all of them. ZingGrow replaces the whole stack.
          </p>
        </div>

        <!-- Comparison table -->
        <div class="animate-on-scroll rounded-2xl border border-gray-200 overflow-hidden shadow-sm">
          <table class="w-full">
            <thead>
              <tr style="background: #0D1B2A;">
                <th class="px-6 py-4 text-left text-white font-semibold text-sm w-1/3">Tool</th>
                <th class="px-6 py-4 text-center text-white/60 font-medium text-sm">Buying Separately</th>
                <th class="px-6 py-4 text-center text-brand-orange font-bold text-sm">
                  ZingGrow
                  <span class="block text-brand-orange-light font-normal text-xs mt-0.5">All included</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {[
                { tool: 'CRM & Pipeline Management', separate: 'HubSpot / Salesforce\n$50–$300/mo', zing: true },
                { tool: 'Email Marketing Platform', separate: 'Mailchimp / Klaviyo\n$30–$150/mo', zing: true },
                { tool: 'SMS Marketing', separate: 'SimpleTexting / EZTexting\n$30–$100/mo', zing: true },
                { tool: 'Appointment Scheduling', separate: 'Calendly / Acuity\n$16–$50/mo', zing: true },
                { tool: 'Review Management', separate: 'Birdeye / Podium\n$200–$400/mo', zing: true },
                { tool: 'Website / Landing Pages', separate: 'Unbounce / Leadpages\n$50–$200/mo', zing: true },
                { tool: 'Reporting & Analytics', separate: 'Various add-ons\n$30–$100/mo', zing: true },
                { tool: 'Human Onboarding & Support', separate: '❌ Not included anywhere', zing: true },
              ].map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-brand-gray/50'}>
                  <td class="px-6 py-4 text-brand-navy font-medium text-sm">{row.tool}</td>
                  <td class="px-6 py-4 text-center text-gray-400 text-xs leading-relaxed whitespace-pre-line">{row.separate}</td>
                  <td class="px-6 py-4 text-center">
                    <div class="flex items-center justify-center">
                      <svg class="w-5 h-5 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                    </div>
                  </td>
                </tr>
              ))}
              <!-- Total row -->
              <tr style="background: #0D1B2A;">
                <td class="px-6 py-5 text-white font-bold text-sm">Total Monthly Cost</td>
                <td class="px-6 py-5 text-center text-red-300 font-bold text-sm">$406–$1,300+/mo<br/><span class="text-red-200/60 font-normal text-xs">Plus setup time and integration headaches</span></td>
                <td class="px-6 py-5 text-center text-brand-orange font-bold text-sm">
                  One flat monthly rate<br/>
                  <span class="text-brand-orange-light font-normal text-xs">Ask us on your demo call</span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="text-center mt-8 animate-on-scroll">
          <a
            href={`${base}/demo`}
            class="btn-primary text-base px-8 py-4"
          >
            Get Your Pricing on a Demo Call
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <p class="text-gray-400 text-sm mt-3">No commitment required. Free 30-day trial available.</p>
        </div>
      </div>
    </section>

    <!-- 8. FAQs -->
    <FAQAccordion />

    <!-- 9. Final CTA -->
    <section class="relative py-20 md:py-28 overflow-hidden" style="background: #0D1B2A;">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full opacity-15"
          style="background: radial-gradient(circle, #F5820A 0%, transparent 70%);"></div>
        <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full opacity-10"
          style="background: radial-gradient(circle, #1A7A8A 0%, transparent 70%);"></div>
      </div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-on-scroll">
          <span class="inline-block px-4 py-1.5 rounded-full bg-brand-orange/20 text-brand-orange-light text-sm font-semibold mb-6">
            Ready to Grow?
          </span>
          <h2 class="text-4xl md:text-5xl font-black text-white leading-tight mb-6">
            Let's Talk About<br/>
            <span class="text-brand-orange">Your Business.</span>
          </h2>
          <p class="text-xl text-white/65 leading-relaxed mb-10 max-w-2xl mx-auto">
            A free 30-minute demo shows you the full platform, how it applies to your specific business, and what your first 90 days would look like with Zing behind you. No pressure, no scripts — just an honest conversation.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a
              href={`${base}/demo`}
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-brand-orange text-white font-bold text-lg shadow-xl hover:bg-brand-orange-dark hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              Schedule Your Free Demo
            </a>
            <a
              href="tel:8778069464"
              class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border-2 border-white/25 text-white font-semibold text-lg hover:bg-white/10 hover:border-white/50 transition-all"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Call (877) 806-9464
            </a>
          </div>

          <p class="text-white/35 text-sm mt-8">
            Founded 2002 · Veteran-Owned · Orem, UT · 1090 N 960 W
          </p>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <StickyCTABar />
  <ScrollAnimator />
</Layout>
