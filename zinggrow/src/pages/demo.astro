---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollAnimator from '../components/ScrollAnimator.astro';

const base = import.meta.env.BASE_URL;

const businessTypes = [
  'Plumbing / HVAC / Electrical',
  'Roofing / Exterior / Construction',
  'Landscaping / Lawn Care',
  'Real Estate / Brokerage',
  'Dental / Medical / Healthcare',
  'Chiropractic / Wellness',
  'Restaurant / Food Service',
  'Retail / E-commerce',
  'Insurance / Financial Services',
  'Legal Services',
  'Marketing / Consulting',
  'Home Services (Other)',
  'Other',
];

const bestTimes = [
  'Mornings (8am–12pm MT)',
  'Afternoons (12pm–5pm MT)',
  'Evenings (5pm–7pm MT)',
  'Anytime is fine',
];

const currentTools = [
  { value: 'mailchimp', label: 'Mailchimp' },
  { value: 'hubspot', label: 'HubSpot' },
  { value: 'activecampaign', label: 'ActiveCampaign' },
  { value: 'salesforce', label: 'Salesforce' },
  { value: 'highlevel', label: 'GoHighLevel (self-managed)' },
  { value: 'calendly', label: 'Calendly / Acuity' },
  { value: 'birdeye', label: 'Birdeye / Podium (reviews)' },
  { value: 'spreadsheets', label: 'Spreadsheets (Excel/Sheets)' },
  { value: 'nothing', label: 'Nothing formal yet' },
  { value: 'other', label: 'Other' },
];

const callExpectations = [
  {
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    title: '30 Minutes, No Pressure',
    desc: 'We show you the platform, answer your questions, and talk honestly about whether Zing is the right fit for you.',
  },
  {
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
    title: 'Tailored to Your Business',
    desc: 'We review what tools you\'re currently using and show you exactly how ZingGrow replaces them — with your actual workflow in mind.',
  },
  {
    icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
    title: 'Meet Your Onboarding Team',
    desc: 'If it\'s a good fit, you\'ll meet the actual person who would handle your onboarding — no bait-and-switch to a different rep.',
  },
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Honest Pricing',
    desc: 'We share flat monthly pricing on the call — no gotchas, no per-seat surprises. You\'ll know exactly what you\'d pay.',
  },
];
---

<Layout
  title="Schedule a Free Demo — ZingGrow by Zing Business Systems"
  description="Book a free 30-minute demo with the ZingGrow team. See the full platform, get honest pricing, and meet the people who would handle your onboarding. No pressure."
>
  <Header currentPage="demo" />

  <main class="pt-16">

    <!-- Demo hero header -->
    <div class="py-16 md:py-20" style="background: #0D1B2A;">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-brand-orange/30 bg-brand-orange/10 text-brand-orange-light text-sm font-semibold mb-5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          Free 30-Minute Demo
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-black text-white leading-tight mb-5">
          Let's See If ZingGrow Is<br class="hidden sm:block" />
          <span class="text-brand-orange">Right for Your Business</span>
        </h1>
        <p class="text-lg text-white/65 max-w-2xl mx-auto leading-relaxed">
          Fill out the form and a member of our team will call you at your preferred time. We'll walk you through the platform, your current tool stack, and what switching would actually look like — no scripts, no hard sell.
        </p>
      </div>
    </div>

    <!-- Form + sidebar section -->
    <section class="py-16 md:py-20 bg-brand-gray">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">

          <!-- Form column (2/3 width) -->
          <div class="lg:col-span-2 animate-on-scroll">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 md:p-10">
              <h2 class="text-2xl font-bold text-brand-navy mb-2">Tell Us a Bit About Your Business</h2>
              <p class="text-gray-500 text-sm mb-8">Takes about 2 minutes. We'll use this to make the call as useful as possible.</p>

              <form
                id="demo-form"
                method="POST"
                action="#"
                class="space-y-6"
                novalidate
              >
                <!-- Name + Business Name row -->
                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="first-name" class="block text-sm font-semibold text-brand-navy mb-1.5">
                      First Name <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="first-name"
                      name="firstName"
                      required
                      autocomplete="given-name"
                      placeholder="Jane"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy placeholder-gray-400 text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors"
                    />
                  </div>
                  <div>
                    <label for="last-name" class="block text-sm font-semibold text-brand-navy mb-1.5">
                      Last Name <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="last-name"
                      name="lastName"
                      required
                      autocomplete="family-name"
                      placeholder="Smith"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy placeholder-gray-400 text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors"
                    />
                  </div>
                </div>

                <!-- Business Name -->
                <div>
                  <label for="business-name" class="block text-sm font-semibold text-brand-navy mb-1.5">
                    Business Name <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="business-name"
                    name="businessName"
                    required
                    autocomplete="organization"
                    placeholder="Smith Plumbing & Heating"
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy placeholder-gray-400 text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors"
                  />
                </div>

                <!-- Business Type -->
                <div>
                  <label for="business-type" class="block text-sm font-semibold text-brand-navy mb-1.5">
                    Business Type <span class="text-red-500">*</span>
                  </label>
                  <div class="relative">
                    <select
                      id="business-type"
                      name="businessType"
                      required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors appearance-none bg-white cursor-pointer"
                    >
                      <option value="" disabled selected>Select your industry…</option>
                      {businessTypes.map(type => (
                        <option value={type}>{type}</option>
                      ))}
                    </select>
                    <div class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2">
                      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>
                  </div>
                </div>

                <!-- Phone + Email row -->
                <div class="grid sm:grid-cols-2 gap-5">
                  <div>
                    <label for="phone" class="block text-sm font-semibold text-brand-navy mb-1.5">
                      Phone Number <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      required
                      autocomplete="tel"
                      placeholder="(555) 000-0000"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy placeholder-gray-400 text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-semibold text-brand-navy mb-1.5">
                      Email Address <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      autocomplete="email"
                      placeholder="jane@smithplumbing.com"
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy placeholder-gray-400 text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors"
                    />
                  </div>
                </div>

                <!-- Current tools -->
                <div>
                  <fieldset>
                    <legend class="block text-sm font-semibold text-brand-navy mb-3">
                      What tools are you currently using? <span class="text-gray-400 font-normal">(check all that apply)</span>
                    </legend>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                      {currentTools.map(tool => (
                        <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-150 hover:border-brand-teal/40 hover:bg-brand-teal/5 cursor-pointer transition-colors group">
                          <input
                            type="checkbox"
                            name="currentTools"
                            value={tool.value}
                            class="w-4 h-4 rounded border-gray-300 text-brand-teal focus:ring-brand-teal focus:ring-2 cursor-pointer"
                          />
                          <span class="text-sm text-gray-700 group-hover:text-brand-navy transition-colors">{tool.label}</span>
                        </label>
                      ))}
                    </div>
                  </fieldset>
                </div>

                <!-- Best time to call -->
                <div>
                  <label for="best-time" class="block text-sm font-semibold text-brand-navy mb-1.5">
                    Best Time to Call <span class="text-red-500">*</span>
                  </label>
                  <div class="relative">
                    <select
                      id="best-time"
                      name="bestTime"
                      required
                      class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors appearance-none bg-white cursor-pointer"
                    >
                      <option value="" disabled selected>Select your preferred time…</option>
                      {bestTimes.map(time => (
                        <option value={time}>{time}</option>
                      ))}
                    </select>
                    <div class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2">
                      <svg class="w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>
                  </div>
                </div>

                <!-- Message / anything else -->
                <div>
                  <label for="message" class="block text-sm font-semibold text-brand-navy mb-1.5">
                    Anything Else We Should Know? <span class="text-gray-400 font-normal">(optional)</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    placeholder="Tell us about your biggest challenge right now, or anything specific you'd like us to cover on the call..."
                    class="w-full px-4 py-3 rounded-xl border border-gray-200 text-brand-navy placeholder-gray-400 text-sm focus:outline-none focus:border-brand-teal focus:ring-2 focus:ring-brand-teal/20 transition-colors resize-none"
                  ></textarea>
                </div>

                <!-- Submit -->
                <div>
                  <button
                    type="submit"
                    id="demo-submit-btn"
                    class="w-full inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-xl bg-brand-orange text-white font-bold text-lg hover:bg-brand-orange-dark transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-brand-orange focus:ring-offset-2"
                  >
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    Request My Free Demo
                  </button>
                  <p class="text-center text-xs text-gray-400 mt-3">
                    We typically respond within a few hours during business hours (MT). No spam, ever.
                  </p>
                </div>

                <!-- Success message (hidden by default) -->
                <div id="form-success" class="hidden rounded-xl bg-green-50 border border-green-200 p-5 text-center">
                  <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-3">
                    <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <h3 class="font-bold text-green-800 text-lg mb-1">You're on the list!</h3>
                  <p class="text-green-700 text-sm">A member of our team will reach out within a few hours to confirm your demo time. Watch for a call from <strong>(877) 806-9464</strong>.</p>
                </div>
              </form>
            </div>
          </div>

          <!-- Sidebar column (1/3 width) -->
          <div class="space-y-6 animate-on-scroll" style="animation-delay: 0.15s;">

            <!-- What to expect -->
            <div class="bg-brand-navy rounded-2xl p-7 text-white">
              <h3 class="font-bold text-lg mb-5 text-white">What to Expect on the Call</h3>
              <div class="space-y-5">
                {callExpectations.map((item, i) => (
                  <div class="flex gap-4">
                    <div class="w-8 h-8 rounded-lg bg-brand-orange/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg class="w-4 h-4 text-brand-orange-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                      </svg>
                    </div>
                    <div>
                      <div class="text-white font-semibold text-sm mb-1">{item.title}</div>
                      <div class="text-white/55 text-xs leading-relaxed">{item.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Call us directly -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
              <h3 class="font-bold text-brand-navy text-base mb-1">Rather Call Us Directly?</h3>
              <p class="text-gray-500 text-sm mb-4">We pick up. No phone tree, no hold music.</p>
              <a
                href="tel:8778069464"
                class="flex items-center gap-3 text-brand-teal font-bold text-xl hover:text-brand-teal-light transition-colors"
              >
                <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                (877) 806-9464
              </a>
              <p class="text-gray-400 text-xs mt-2">Mon–Fri, 8am–6pm MT</p>
            </div>

            <!-- Trust signals -->
            <div class="bg-brand-teal/5 border border-brand-teal/20 rounded-2xl p-6">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 rounded-full bg-brand-teal/15 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-brand-navy text-sm">Your Info Is Safe</div>
                  <div class="text-gray-500 text-xs">We never sell or share your information</div>
                </div>
              </div>
              <ul class="space-y-2">
                {[
                  'Founded 2002 — 24 years in business',
                  'Veteran-owned American company',
                  'Orem, Utah — real people, real office',
                  'Free 30-day trial available',
                ].map(item => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-3.5 h-3.5 text-brand-teal flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Screenshot teaser -->
            <div class="rounded-2xl overflow-hidden shadow-sm border border-gray-100">
              <img
                src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&auto=format&fit=crop&q=80"
                alt="ZingGrow platform analytics dashboard preview"
                class="w-full h-40 object-cover"
                loading="lazy"
              />
              <div class="px-5 py-4 bg-white">
                <div class="text-brand-navy font-semibold text-sm mb-1">See the Full Platform on Your Demo</div>
                <div class="text-gray-500 text-xs">We do a live screen share — no slide decks, no stock videos.</div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <ScrollAnimator />
</Layout>

<script>
  const form = document.getElementById('demo-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('demo-submit-btn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    // Basic validation
    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach((field) => {
      const input = field as HTMLInputElement | HTMLSelectElement;
      if (!input.value.trim()) {
        valid = false;
        input.classList.add('border-red-400', 'ring-2', 'ring-red-200');
      } else {
        input.classList.remove('border-red-400', 'ring-2', 'ring-red-200');
      }
    });

    if (!valid) return;

    // Show success
    if (submitBtn) submitBtn.classList.add('hidden');
    if (successMsg) successMsg.classList.remove('hidden');
    successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Remove red border on input
  form?.querySelectorAll('input, select, textarea').forEach((field) => {
    field.addEventListener('input', () => {
      field.classList.remove('border-red-400', 'ring-2', 'ring-red-200');
    });
  });
</script>
